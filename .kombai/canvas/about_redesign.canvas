      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --font-display: 'Inter', system-ui, sans-serif;\n    --font-serif: 'EB Garamond', serif;\n    --font-sans: 'Inter', sans-serif;\n    \n    --color-bg: #0a0a0b;\n    --color-surface: #141416;\n    --color-surface-raised: #1c1c1f;\n    --color-border: rgba(255, 255, 255, 0.08);\n    --color-accent: #c8bfff;\n    --color-vitality: #d9f99d;\n    --color-text-primary: #fafafa;\n    --color-text-secondary: #a1a1aa;\n    --color-text-muted: #71717a;\n    --spacing-section-gap: 96px;\n    --theme-card-hover-shadow: 0 16px 40px rgba(0, 0, 0, 0.35);\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-text-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .section-label {\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: var(--color-text-secondary);\n    margin-bottom: 0.75rem;\n    display: inline-block;\n  }\n\n  .card {\n    background: var(--color-surface);\n    border: 1px solid var(--color-border);\n    border-radius: 16px;\n    padding: 2rem;\n    transition: border-color 200ms ease, box-shadow 280ms cubic-bezier(0.22, 1, 0.36, 1);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .card-wobble:hover {\n    filter: url(#wobble-filter);\n  }\n\n  .card-interactive:hover {\n    transform: translateY(-4px);\n    border-color: rgba(200, 191, 255, 0.22);\n    box-shadow: var(--theme-card-hover-shadow);\n  }\n\n  .font-display { font-family: var(--font-display); font-weight: 600; letter-spacing: -0.02em; }\n  .font-italic-serif { font-family: var(--font-serif); font-style: italic; }\n\n  .about-page-grid {\n    position: absolute;\n    inset: 0;\n    background-image: linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),\n                      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);\n    background-size: 56px 56px;\n    mask-image: radial-gradient(ellipse 85% 65% at 50% 20%, black 15%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .about-page-orb {\n    position: absolute;\n    border-radius: 9999px;\n    filter: blur(80px);\n    opacity: 0.1;\n    pointer-events: none;\n    will-change: transform;\n  }\n\n  .helix-path {\n    stroke: var(--color-accent);\n    stroke-width: 2;\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n  }\n\n  .interest-pill {\n    padding: 0.625rem 1rem;\n    border-radius: 9999px;\n    background: var(--color-surface-raised);\n    border: 1px solid var(--color-border);\n    font-size: 0.8125rem;\n    color: var(--color-text-primary);\n    position: relative;\n    overflow: hidden;\n    cursor: default;\n    z-index: 1;\n  }\n\n  .interest-pill::before {\n    content: '';\n    position: absolute;\n    width: 0;\n    height: 0;\n    background: radial-gradient(circle, rgba(217, 249, 157, 0.2) 0%, transparent 70%);\n    border-radius: 50%;\n    transform: translate(-50%, -50%);\n    transition: width 0.6s, height 0.6s;\n    z-index: -1;\n    pointer-events: none;\n  }\n\n  .interest-pill:hover::before {\n    width: 300px;\n    height: 300px;\n  }\n\n  .interest-pill:hover {\n    border-color: var(--color-vitality);\n    color: var(--color-vitality);\n  }\n\n  /* Sparkle Specifics */\n  .biological-span {\n    position: relative;\n    cursor: pointer;\n    display: inline-block;\n  }\n\n  .biological-bg {\n    position: absolute;\n    inset: -15px;\n    background: radial-gradient(circle, #06b6d4 0%, #d946ef 100%);\n    filter: blur(25px);\n    opacity: 0;\n    transition: opacity 0.5s;\n    z-index: -1;\n    border-radius: 50%;\n    pointer-events: none;\n  }\n\n  .biological-span:hover .biological-bg {\n    opacity: 0.3;\n    animation: pulse-polychromatic 3s infinite alternate;\n  }\n\n  @keyframes pulse-polychromatic {\n    0% { transform: scale(0.8) rotate(0deg); filter: blur(20px); }\n    100% { transform: scale(1.3) rotate(180deg); filter: blur(35px); }\n  }\n\n  .title-division {\n    opacity: 0;\n    filter: blur(20px);\n    transform: scaleY(0.1);\n  }\n\n  .ripple-node {\n    position: absolute;\n    border: 1px solid var(--color-vitality);\n    border-radius: 50%;\n    width: 16px;\n    height: 16px;\n    transform: translate(-50%, -50%) scale(1);\n    opacity: 0;\n    pointer-events: none;\n  }\n\n  .particle {\n    position: absolute;\n    width: 3px;\n    height: 3px;\n    background: var(--color-vitality);\n    border-radius: 50%;\n    pointer-events: none;\n  }\n</style>\n\n\n<svg style=\"display: none;\" data-kid=\"21\">\n  <filter id=\"wobble-filter\" data-kid=\"38\">\n    <feTurbulence type=\"fractalNoise\" baseFrequency=\"0.01\" numOctaves=\"2\" result=\"warp\" data-kid=\"39\">\n      <animate attributeName=\"baseFrequency\" values=\"0.01;0.05;0.01\" dur=\"2s\" repeatCount=\"indefinite\" data-kid=\"40\"></animate>\n    </feTurbulence>\n    <feDisplacementMap in=\"SourceGraphic\" in2=\"warp\" scale=\"3\" data-kid=\"41\"></feDisplacementMap>\n  </filter>\n</svg>\n\n<div class=\"relative min-h-screen\" data-kid=\"1\">\n  \n  <div class=\"fixed inset-0 z-0\" data-kid=\"2\">\n    <div class=\"about-page-grid\" data-kid=\"3\"></div>\n    <div class=\"about-page-orb w-[500px] h-[500px] bg-purple-500/20 top-[10%] -right-[10%]\" data-kid=\"4\"></div>\n    <div class=\"about-page-orb w-[400px] h-[400px] bg-teal-500/10 bottom-[10%] -left-[10%]\" data-kid=\"5\"></div>\n  </div>\n\n  <main class=\"relative z-10 max-w-6xl mx-auto px-6 py-[var(--spacing-section-gap)]\" data-kid=\"6\">\n    \n    <header class=\"mb-32\" data-kid=\"7\">\n      <div class=\"max-w-3xl\" data-kid=\"8\">\n        <span class=\"section-label\" data-kid=\"9\">Polychromatic Pulse — Sparkle Edition</span>\n        <h1 id=\"hero-title\" class=\"font-display text-5xl md:text-7xl leading-[1.1] mb-8\" data-kid=\"10\">\n          The <span class=\"biological-span font-italic-serif text-white\" data-kid=\"11\">Biological<div class=\"biological-bg\" data-kid=\"42\"></div></span> Blueprint <br data-kid=\"12\">\n          of Software Architecture.\n        </h1>\n        <p class=\"text-xl text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"13\">\n          Synthesizing scientific precision with cloud-native engineering. My background in <span class=\"font-italic-serif text-white\" data-kid=\"14\">Bioengineering</span> provides a unique vantage point on system resilience and homeostasis.\n        </p>\n      </div>\n    </header>\n\n    \n    <section class=\"mb-32\" data-kid=\"15\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\" data-kid=\"16\">\n        <div class=\"lg:col-span-6 space-y-12\" data-kid=\"17\">\n          <div data-kid=\"18\">\n            <span class=\"section-label\" data-kid=\"19\">Evolution Path</span>\n            <h2 class=\"font-display text-4xl mb-6\" data-kid=\"20\">The Career Helix</h2>\n          </div>\n          \n          <div class=\"space-y-8 relative\" data-kid=\"22\">\n            <div class=\"milestone-text group opacity-50 transition-opacity duration-500 cursor-pointer\" data-index=\"0\" data-kid=\"23\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"24\">01. Physiological Foundations</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"25\">Decoding bio-signals and modeling homeostatic feedback loops in clinical environments.</p>\n            </div>\n            <div class=\"milestone-text group opacity-50 transition-opacity duration-500 cursor-pointer\" data-index=\"1\" data-kid=\"26\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"27\">02. Data Translation</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"28\">Scaling clinical research pipelines and orchestrating medical datasets for signal analysis.</p>\n            </div>\n            <div class=\"milestone-text group opacity-50 transition-opacity duration-500 cursor-pointer\" data-index=\"2\" data-kid=\"29\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"30\">03. Backend Evolution</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"31\">Pivoting logic from biological cells to distributed software cells—transitioning to microservices.</p>\n            </div>\n            <div class=\"milestone-text group opacity-50 transition-opacity duration-500 cursor-pointer\" data-index=\"3\" data-kid=\"32\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"33\">04. Platform Architecture</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"34\">Building resilient, self-healing infrastructures that mimic biological adaptability at scale.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-6 sticky top-24 h-[600px] flex items-center justify-center\" data-kid=\"35\">\n          <div class=\"relative w-full h-full max-w-[400px]\" data-kid=\"36\">\n            <svg id=\"helix-svg\" viewBox=\"0 0 200 600\" class=\"w-full h-full overflow-visible\" data-kid=\"37\">\n              <path id=\"helix-path-bg\" d=\"M100 0 C150 150 50 150 100 300 C150 450 50 450 100 600\" fill=\"none\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"2\" data-kid=\"43\"></path>\n              <path id=\"helix-path\" class=\"helix-path\" d=\"M100 0 C150 150 50 150 100 300 C150 450 50 450 100 600\" fill=\"none\" data-kid=\"44\"></path>\n              \n              \n              <circle id=\"helix-spark\" r=\"4\" fill=\"white\" style=\"filter: drop-shadow(0 0 8px white); opacity: 0;\" data-kid=\"45\"></circle>\n\n              <circle class=\"helix-node\" cx=\"100\" cy=\"0\" r=\"5\" fill=\"var(--color-bg)\" stroke=\"var(--color-accent)\" stroke-width=\"2\" data-index=\"0\" data-kid=\"46\"></circle>\n              <circle class=\"helix-node\" cx=\"100\" cy=\"150\" r=\"5\" fill=\"var(--color-bg)\" stroke=\"var(--color-accent)\" stroke-width=\"2\" data-index=\"1\" data-kid=\"47\"></circle>\n              <circle class=\"helix-node\" cx=\"100\" cy=\"450\" r=\"5\" fill=\"var(--color-bg)\" stroke=\"var(--color-accent)\" stroke-width=\"2\" data-index=\"2\" data-kid=\"77\"></circle>\n              <circle class=\"helix-node\" cx=\"100\" cy=\"600\" r=\"5\" fill=\"var(--color-bg)\" stroke=\"var(--color-accent)\" stroke-width=\"2\" data-index=\"3\" data-kid=\"78\"></circle>\n            </svg>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-32\" data-kid=\"48\">\n      <span class=\"section-label\" data-kid=\"49\">Interdisciplinary Mapping</span>\n      <h2 class=\"font-display text-4xl mb-12\" data-kid=\"50\">The Bio Bridge</h2>\n      \n      <div class=\"card p-0 overflow-hidden\" data-kid=\"51\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2\" data-kid=\"52\">\n          <div class=\"p-8 border-r border-[var(--color-border)]\" data-kid=\"53\">\n            <h4 class=\"text-xs uppercase tracking-widest text-[var(--color-text-muted)] mb-8\" data-kid=\"54\">Concept Transfer</h4>\n            <div class=\"space-y-4\" data-kid=\"55\">\n              <div class=\"bio-bridge-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] transition-colors cursor-pointer\" data-id=\"1\" data-kid=\"56\">\n                <div class=\"flex flex-col\" data-kid=\"57\">\n                  <span class=\"scramble-text font-italic-serif text-white\" data-original=\"Signal Processing\" data-kid=\"58\">Signal Processing</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"59\">Noise filtration & Sampling</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--color-vitality)] transition-colors\" data-kid=\"60\"></i>\n              </div>\n              <div class=\"bio-bridge-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] transition-colors cursor-pointer\" data-id=\"2\" data-kid=\"61\">\n                <div class=\"flex flex-col\" data-kid=\"62\">\n                  <span class=\"scramble-text font-italic-serif text-white\" data-original=\"Homeostasis\" data-kid=\"63\">Homeostasis</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"64\">Self-regulation & Feedback</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--color-vitality)] transition-colors\" data-kid=\"65\"></i>\n              </div>\n              <div class=\"bio-bridge-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] transition-colors cursor-pointer\" data-id=\"3\" data-kid=\"66\">\n                <div class=\"flex flex-col\" data-kid=\"67\">\n                  <span class=\"scramble-text font-italic-serif text-white\" data-original=\"Metabolic Pathways\" data-kid=\"68\">Metabolic Pathways</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"69\">Energy & Resource Orchestration</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--color-vitality)] transition-colors\" data-kid=\"70\"></i>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"p-8 bg-white/[0.01] flex items-center justify-center relative\" id=\"bridge-visual\" data-kid=\"71\">\n            <div class=\"relative w-full aspect-square max-w-[300px]\" data-kid=\"72\">\n              <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"73\">\n                <div class=\"w-24 h-24 rounded-full border border-white/5 bg-white/[0.02] flex items-center justify-center\" data-kid=\"74\">\n                  <i class=\"ti ti-dna text-3xl text-[var(--color-accent)]\" data-kid=\"75\"></i>\n                </div>\n              </div>\n              \n              <svg id=\"bridge-svg\" class=\"absolute inset-0 w-full h-full overflow-visible\" viewBox=\"0 0 300 300\" data-kid=\"76\">\n                <path class=\"connector-path\" data-id=\"1\" d=\"M50 150 Q 150 50 250 50\" fill=\"none\" stroke=\"white\" stroke-width=\"1\" opacity=\"0.2\" stroke-dasharray=\"4 4\" data-kid=\"79\"></path>\n                <path class=\"connector-path\" data-id=\"2\" d=\"M50 150 Q 150 150 250 150\" fill=\"none\" stroke=\"white\" stroke-width=\"1\" opacity=\"0.2\" stroke-dasharray=\"4 4\" data-kid=\"130\"></path>\n                <path class=\"connector-path\" data-id=\"3\" d=\"M50 150 Q 150 250 250 250\" fill=\"none\" stroke=\"white\" stroke-width=\"1\" opacity=\"0.2\" stroke-dasharray=\"4 4\" data-kid=\"131\"></path>\n              </svg>\n              \n              <div class=\"absolute top-[35px] right-0 flex items-center gap-3\" data-kid=\"80\">\n                <div class=\"w-8 h-8 rounded-lg bg-surface-raised border border-white/10 flex items-center justify-center\" data-kid=\"81\"><i class=\"ti ti-wave-square text-xs\" data-kid=\"82\"></i></div>\n                <span class=\"text-xs font-display\" data-kid=\"83\">Event Streaming</span>\n              </div>\n              <div class=\"absolute top-[135px] right-0 flex items-center gap-3\" data-kid=\"84\">\n                <div class=\"w-8 h-8 rounded-lg bg-surface-raised border border-white/10 flex items-center justify-center\" data-kid=\"85\"><i class=\"ti ti-arrows-maximize text-xs\" data-kid=\"86\"></i></div>\n                <span class=\"text-xs font-display\" data-kid=\"87\">Autoscaling</span>\n              </div>\n              <div class=\"absolute bottom-[35px] right-0 flex items-center gap-3\" data-kid=\"88\">\n                <div class=\"w-8 h-8 rounded-lg bg-surface-raised border border-white/10 flex items-center justify-center\" data-kid=\"89\"><i class=\"ti ti-stack-2 text-xs\" data-kid=\"90\"></i></div>\n                <span class=\"text-xs font-display\" data-kid=\"91\">Data Pipelines</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-32\" data-kid=\"92\">\n      <span class=\"section-label\" data-kid=\"93\">Core Engineering Mindset</span>\n      <h2 class=\"font-display text-4xl mb-12\" data-kid=\"94\">Core Principles</h2>\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"95\">\n        <div class=\"card card-interactive card-wobble vitality-glow-hover flex flex-col items-start h-full\" data-kid=\"96\">\n          <div class=\"mindset-icon w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-8 border border-accent/20\" data-kid=\"97\">\n            <i class=\"ti ti-microscope text-xl text-[var(--color-accent)]\" data-kid=\"98\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"99\">Precision-First</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"100\">Applying clinical-grade attention to detail in every line of code and infrastructure configuration.</p>\n        </div>\n        \n        <div class=\"card card-interactive card-wobble vitality-glow-hover flex flex-col items-start h-full\" data-kid=\"101\">\n          <div class=\"mindset-icon w-12 h-12 rounded-xl bg-vitality/10 flex items-center justify-center mb-8 border border-vitality/20\" data-kid=\"102\">\n            <i class=\"ti ti-refresh text-xl text-[var(--color-vitality)]\" data-kid=\"103\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"104\">Adaptive Design</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"105\">Building systems that embrace failure as a signal for self-correction, much like biological organisms.</p>\n        </div>\n        \n        <div class=\"card card-interactive card-wobble vitality-glow-hover flex flex-col items-start h-full\" data-kid=\"106\">\n          <div class=\"mindset-icon w-12 h-12 rounded-xl bg-teal-400/10 flex items-center justify-center mb-8 border border-teal-400/20\" data-kid=\"107\">\n            <i class=\"ti ti-server text-xl text-teal-400\" data-kid=\"108\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"109\">Systemic Scalability</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"110\">Understanding the interconnected nature of services to ensure growth doesn't compromise stability.</p>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-32\" data-kid=\"111\">\n      <div class=\"text-center\" data-kid=\"112\">\n        <span class=\"section-label\" data-kid=\"113\">Curiosities & Explorations</span>\n        <h2 class=\"font-italic-serif text-4xl text-white mb-12\" data-kid=\"114\">Interests</h2>\n        \n        <div class=\"flex flex-wrap justify-center gap-4 max-w-3xl mx-auto\" id=\"interests-container\" data-kid=\"115\">\n          <div class=\"interest-pill\" data-kid=\"116\">Machine Learning</div>\n          <div class=\"interest-pill\" data-kid=\"117\">Genomics</div>\n          <div class=\"interest-pill\" data-kid=\"118\">Distributed Systems</div>\n          <div class=\"interest-pill\" data-kid=\"119\">Analog Synthesis</div>\n          <div class=\"interest-pill\" data-kid=\"120\">Computational Biology</div>\n          <div class=\"interest-pill\" data-kid=\"121\">Platform Engineering</div>\n        </div>\n      </div>\n    </section>\n\n  </main>\n\n  <footer class=\"max-w-6xl mx-auto px-6 py-12 border-t border-[var(--color-border)] flex justify-between items-center text-[10px] tracking-widest text-[var(--color-text-muted)] uppercase font-display\" data-kid=\"122\">\n    <div data-kid=\"123\">&copy; 2026 Esteban</div>\n    <div class=\"flex gap-8\" data-kid=\"124\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"125\">GitHub</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"126\">LinkedIn</a>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"127\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"128\"></script>\n<script data-kid=\"129\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // 1. Cellular Division Title Reveal\n  const title = document.getElementById('hero-title');\n  const words = title.innerText.split(' ');\n  title.innerHTML = words.map(w => `<span class=\"title-division inline-block\">${w}</span>`).join(' ');\n  gsap.to('.title-division', {\n    opacity: 1,\n    filter: 'blur(0px)',\n    scaleY: 1,\n    duration: 1.2,\n    stagger: 0.1,\n    ease: 'power4.out'\n  });\n\n  // 2. Negative Magnetism for Orbs\n  document.addEventListener('mousemove', (e) => {\n    const orbs = document.querySelectorAll('.about-page-orb');\n    orbs.forEach(orb => {\n      const rect = orb.getBoundingClientRect();\n      const centerX = rect.left + rect.width / 2;\n      const centerY = rect.top + rect.height / 2;\n      const dx = e.clientX - centerX;\n      const dy = e.clientY - centerY;\n      const dist = Math.sqrt(dx*dx + dy*dy);\n      if (dist < 500) {\n        const angle = Math.atan2(dy, dx);\n        const force = (500 - dist) / 15;\n        gsap.to(orb, {\n          x: -Math.cos(angle) * force,\n          y: -Math.sin(angle) * force,\n          duration: 0.6,\n          ease: 'power2.out'\n        });\n      }\n    });\n  });\n\n  // 3. Helix Scroll + Spark + Milestone Highlighting\n  const helixPath = document.getElementById('helix-path');\n  const spark = document.getElementById('helix-spark');\n  \n  gsap.to(helixPath, {\n    strokeDashoffset: 0,\n    ease: 'none',\n    scrollTrigger: {\n      trigger: '#helix-svg',\n      start: 'top 60%',\n      end: 'bottom 40%',\n      scrub: 0.5,\n      onUpdate: (self) => {\n        const length = helixPath.getTotalLength();\n        const point = helixPath.getPointAtLength(length * self.progress);\n        gsap.set(spark, { cx: point.x, cy: point.y, opacity: self.progress > 0 ? 1 : 0 });\n      }\n    }\n  });\n\n  document.querySelectorAll('.milestone-text').forEach(el => {\n    el.addEventListener('mouseenter', () => {\n      const idx = el.dataset.index;\n      const node = document.querySelector(`.helix-node[data-index=\"${idx}\"]`);\n      // Create ripple effect\n      const ripple = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n      ripple.setAttribute(\"cx\", node.getAttribute('cx'));\n      ripple.setAttribute(\"cy\", node.getAttribute('cy'));\n      ripple.setAttribute(\"r\", \"5\");\n      ripple.setAttribute(\"fill\", \"none\");\n      ripple.setAttribute(\"stroke\", \"var(--color-vitality)\");\n      document.getElementById('helix-svg').appendChild(ripple);\n      \n      gsap.to(ripple, {\n        r: 30,\n        opacity: 0,\n        duration: 1,\n        ease: 'power2.out',\n        onComplete: () => ripple.remove()\n      });\n      gsap.to(el, { opacity: 1, duration: 0.3 });\n    });\n    el.addEventListener('mouseleave', () => {\n      gsap.to(el, { opacity: 0.5, duration: 0.3 });\n    });\n  });\n\n  // 4. Bio Bridge: Particles + Scramble\n  const bridgeItems = document.querySelectorAll('.bio-bridge-item');\n  bridgeItems.forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      const id = item.dataset.id;\n      const path = document.querySelector(`.connector-path[data-id=\"${id}\"]`);\n      gsap.to(path, { stroke: '#d9f99d', opacity: 1, strokeDasharray: 0, duration: 0.3 });\n      \n      // Spawn particles\n      for (let i = 0; i < 5; i++) {\n        const p = document.createElement('div');\n        p.className = 'particle';\n        document.getElementById('bridge-visual').appendChild(p);\n        const length = path.getTotalLength();\n        gsap.to(p, {\n          duration: 1.5,\n          repeat: -1,\n          delay: i * 0.3,\n          ease: 'none',\n          onUpdate: function() {\n            const pt = path.getPointAtLength(length * this.progress());\n            gsap.set(p, { left: pt.x + (document.getElementById('bridge-visual').offsetWidth/2 - 150), top: pt.y + (document.getElementById('bridge-visual').offsetHeight/2 - 150) });\n          }\n        });\n      }\n    });\n    \n    item.addEventListener('mouseleave', () => {\n      const id = item.dataset.id;\n      gsap.to(`.connector-path[data-id=\"${id}\"]`, { stroke: 'white', opacity: 0.2, strokeDasharray: '4 4', duration: 0.3 });\n      document.querySelectorAll('.particle').forEach(p => p.remove());\n    });\n\n    item.addEventListener('click', () => {\n      const textEl = item.querySelector('.scramble-text');\n      const original = textEl.dataset.original;\n      const chars = \"ATCG\";\n      let iterations = 0;\n      const interval = setInterval(() => {\n        textEl.innerText = original.split(\"\").map(() => chars[Math.floor(Math.random() * chars.length)]).join(\"\");\n        if (iterations >= 10) {\n          clearInterval(interval);\n          textEl.innerText = original;\n        }\n        iterations++;\n      }, 50);\n      gsap.fromTo(item, { backgroundColor: 'rgba(217, 249, 157, 0.1)' }, { backgroundColor: 'transparent', duration: 0.5 });\n    });\n  });\n\n  // 5. Card Icons Jelly Spring\n  document.querySelectorAll('.card').forEach(card => {\n    const icon = card.querySelector('.mindset-icon');\n    card.addEventListener('mouseenter', () => {\n      gsap.to(icon, { scale: 1.2, rotation: 10, duration: 0.6, ease: \"elastic.out(1.2, 0.4)\" });\n    });\n    card.addEventListener('mouseleave', () => {\n      gsap.to(icon, { scale: 1, rotation: 0, duration: 0.4, ease: \"power2.out\" });\n    });\n  });\n\n  // 6. Interest Pill cursor tracking for color spread\n  document.querySelectorAll('.interest-pill').forEach(pill => {\n    pill.addEventListener('mousemove', (e) => {\n      const rect = pill.getBoundingClientRect();\n      const x = e.clientX - rect.left;\n      const y = e.clientY - rect.top;\n      pill.style.setProperty('--x', `${x}px`);\n      pill.style.setProperty('--y', `${y}px`);\n      // Update pseudoelement position\n      const before = pill.querySelector('::before'); // Not accessible via JS directly, use inline style hack or just let CSS handle it\n    });\n  });\n</script>",

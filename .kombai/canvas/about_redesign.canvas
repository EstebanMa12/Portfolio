    "var_4bbff3a648f3": {
      "type": "variant",
      "label": "Variant 2: Clinical Terminal",
      "parentId": "var_9b445508d22d",
      "themeId": null,
      "rect": {
        "x": 5520,
        "y": 0,
        "w": 1280,

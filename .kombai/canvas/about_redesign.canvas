      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --font-display: 'Inter', system-ui, sans-serif;\n    --font-serif: 'EB Garamond', serif;\n    --font-sans: 'Inter', sans-serif;\n    --color-bg: #0a0a0b;\n    --color-surface: #141416;\n    --color-surface-raised: #1c1c1f;\n    --color-border: rgba(255, 255, 255, 0.08);\n    --color-accent: #c8bfff;\n    --color-vitality: #d9f99d;\n    --color-text-primary: #fafafa;\n    --color-text-secondary: #a1a1aa;\n    --color-text-muted: #71717a;\n    --spacing-section-gap: 96px;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-text-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .section-label {\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: var(--color-text-secondary);\n    margin-bottom: 0.75rem;\n    display: inline-block;\n  }\n\n  .card {\n    background: var(--color-surface);\n    border: 1px solid var(--color-border);\n    border-radius: 16px;\n    padding: 2rem;\n    position: relative;\n    overflow: hidden;\n    transition: border-color 200ms ease;\n  }\n\n  .font-display { font-family: var(--font-display); font-weight: 600; letter-spacing: -0.02em; }\n  .font-italic-serif { font-family: var(--font-serif); font-style: italic; }\n\n  /* Grid & Mycelium Background */\n  .about-page-grid {\n    position: absolute;\n    inset: 0;\n    background-image: linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),\n                      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);\n    background-size: 56px 56px;\n    mask-image: radial-gradient(ellipse 85% 65% at 50% 20%, black 15%, transparent 70%);\n    pointer-events: none;\n  }\n\n  #mycelium-canvas {\n    position: fixed;\n    inset: 0;\n    z-index: 1;\n    pointer-events: none;\n    opacity: 0.4;\n  }\n\n  /* Shifting Text Shadow */\n  .shifting-shadow {\n    color: #fff;\n    text-shadow: 0 0 20px rgba(200, 191, 255, 0.2);\n    animation: shadow-orbit 10s infinite linear;\n  }\n\n  @keyframes shadow-orbit {\n    0% { text-shadow: 10px 0 20px rgba(200, 191, 255, 0.15); }\n    25% { text-shadow: 0 10px 20px rgba(200, 191, 255, 0.15); }\n    50% { text-shadow: -10px 0 20px rgba(200, 191, 255, 0.15); }\n    75% { text-shadow: 0 -10px 20px rgba(200, 191, 255, 0.15); }\n    100% { text-shadow: 10px 0 20px rgba(200, 191, 255, 0.15); }\n  }\n\n  /* Helix Branches */\n  .branch-path {\n    stroke: var(--color-vitality);\n    stroke-width: 1;\n    fill: none;\n    opacity: 0;\n    stroke-dasharray: 100;\n    stroke-dashoffset: 100;\n  }\n\n  /* Tonometry Effect */\n  .tonometry-item {\n    perspective: 1000px;\n    transition: transform 0.1s ease-out;\n  }\n\n  /* 3D DNA */\n  .dna-3d-container {\n    cursor: grab;\n    transform-style: preserve-3d;\n  }\n  .dna-3d-container:active { cursor: grabbing; }\n\n  /* Fractal Veins */\n  .vein-overlay {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0;\n    transition: opacity 0.5s ease;\n  }\n  .card:hover .vein-overlay { opacity: 0.15; }\n  .vein-path {\n    stroke: var(--color-vitality);\n    stroke-width: 1.5;\n    fill: none;\n    stroke-dasharray: 200;\n    stroke-dashoffset: 200;\n  }\n\n  /* Synaptic Interest Connectors */\n  .interest-pill {\n    padding: 0.625rem 1rem;\n    border-radius: 9999px;\n    background: var(--color-surface-raised);\n    border: 1px solid var(--color-border);\n    font-size: 0.8125rem;\n    color: var(--color-text-primary);\n    transition: all 0.3s ease;\n    cursor: pointer;\n    position: relative;\n    z-index: 10;\n  }\n  .interest-pill.is-active {\n    border-color: var(--color-vitality);\n    background: rgba(217, 249, 157, 0.1);\n    box-shadow: 0 0 15px rgba(217, 249, 157, 0.2);\n  }\n\n  #synapse-svg {\n    position: fixed;\n    inset: 0;\n    pointer-events: none;\n    z-index: 5;\n  }\n</style>\n\n<canvas id=\"mycelium-canvas\" data-kid=\"1\"></canvas>\n<svg id=\"synapse-svg\" data-kid=\"2\"></svg>\n\n<div class=\"relative min-h-screen\" data-kid=\"3\">\n  <div class=\"fixed inset-0 z-0 pointer-events-none\" data-kid=\"4\">\n    <div class=\"about-page-grid\" data-kid=\"5\"></div>\n    <div class=\"about-page-orb w-[500px] h-[500px] bg-purple-500/10 top-[10%] -right-[10%] opacity-20\" data-kid=\"6\"></div>\n    <div class=\"about-page-orb w-[400px] h-[400px] bg-teal-500/05 bottom-[10%] -left-[10%] opacity-20\" data-kid=\"7\"></div>\n  </div>\n\n  <main class=\"relative z-10 max-w-6xl mx-auto px-6 py-[var(--spacing-section-gap)]\" data-kid=\"8\">\n    \n    <header class=\"mb-32\" data-kid=\"9\">\n      <div class=\"max-w-3xl\" data-kid=\"10\">\n        <span class=\"section-label\" data-kid=\"11\">Redesign — Variant 3 Sparkles</span>\n        <h1 class=\"font-display text-5xl md:text-7xl leading-[1.1] mb-8\" data-kid=\"12\">\n          The <span class=\"font-italic-serif text-white\" data-kid=\"13\">Biological</span> Blueprint <br data-kid=\"14\">\n          <span class=\"shifting-shadow\" data-kid=\"15\">of Software Architecture.</span>\n        </h1>\n        <p class=\"text-xl text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"16\">\n          Synthesizing scientific precision with cloud-native engineering. My background in <span class=\"font-italic-serif text-white\" data-kid=\"17\">Bioengineering</span> provides a unique vantage point on system resilience and homeostasis.\n        </p>\n      </div>\n    </header>\n\n    <section class=\"mb-32\" data-kid=\"18\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\" data-kid=\"19\">\n        <div class=\"lg:col-span-6 space-y-12\" data-kid=\"20\">\n          <div data-kid=\"21\">\n            <span class=\"section-label\" data-kid=\"22\">Evolution Path</span>\n            <h2 class=\"font-display text-4xl mb-6\" data-kid=\"23\">The Career Helix</h2>\n            <p class=\"text-lg text-[var(--color-text-secondary)] mb-8\" data-kid=\"24\">\n              A trajectory defined by the translation of biological complexity into technical architecture. Every step represents a mutation towards higher systemic abstraction.\n            </p>\n          </div>\n          \n          <div class=\"space-y-8 relative\" data-kid=\"25\">\n            <div class=\"milestone-text opacity-30 transition-opacity duration-500\" data-index=\"0\" data-kid=\"26\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"27\">01. Physiological Foundations</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"28\">Decoding bio-signals and modeling homeostatic feedback loops in clinical environments.</p>\n            </div>\n            <div class=\"milestone-text opacity-30 transition-opacity duration-500\" data-index=\"1\" data-kid=\"29\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"30\">02. Data Translation</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"31\">Scaling clinical research pipelines and orchestrating medical datasets for signal analysis.</p>\n            </div>\n            <div class=\"milestone-text opacity-30 transition-opacity duration-500\" data-index=\"2\" data-kid=\"32\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"33\">03. Backend Evolution</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"34\">Pivoting logic from biological cells to distributed software cells—transitioning to microservices.</p>\n            </div>\n            <div class=\"milestone-text opacity-30 transition-opacity duration-500\" data-index=\"3\" data-kid=\"35\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"36\">04. Platform Architecture</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"37\">Building resilient, self-healing infrastructures that mimic biological adaptability at scale.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-6 sticky top-24 h-[600px] flex items-center justify-center\" data-kid=\"38\">\n          <div class=\"relative w-full h-full max-w-[400px]\" data-kid=\"39\">\n            <svg id=\"helix-svg\" viewBox=\"0 0 200 600\" class=\"w-full h-full overflow-visible\" data-kid=\"40\">\n              <path id=\"helix-path\" class=\"helix-path\" d=\"M100,0 C150,150 50,150 100,300 C150,450 50,450 100,600\" fill=\"none\" data-kid=\"41\"></path>\n              \n              \n              <g class=\"helix-group\" data-index=\"0\" data-kid=\"42\">\n                <circle cx=\"100\" cy=\"0\" r=\"6\" fill=\"#0a0a0b\" stroke=\"#c8bfff\" stroke-width=\"2\" data-kid=\"43\"></circle>\n                <path class=\"branch-path\" d=\"M106,0 Q120,-10 140,0\" data-kid=\"44\"></path>\n              </g>\n              <g class=\"helix-group\" data-index=\"1\" data-kid=\"45\">\n                <circle cx=\"100\" cy=\"200\" r=\"6\" fill=\"#0a0a0b\" stroke=\"#c8bfff\" stroke-width=\"2\" data-kid=\"46\"></circle>\n                <path class=\"branch-path\" d=\"M106,200 Q120,190 140,200\" data-kid=\"47\"></path>\n              </g>\n              <g class=\"helix-group\" data-index=\"2\" data-kid=\"48\">\n                <circle cx=\"100\" cy=\"400\" r=\"6\" fill=\"#0a0a0b\" stroke=\"#c8bfff\" stroke-width=\"2\" data-kid=\"49\"></circle>\n                <path class=\"branch-path\" d=\"M106,400 Q120,390 140,400\" data-kid=\"50\"></path>\n              </g>\n              <g class=\"helix-group\" data-index=\"3\" data-kid=\"51\">\n                <circle cx=\"100\" cy=\"600\" r=\"6\" fill=\"#0a0a0b\" stroke=\"#c8bfff\" stroke-width=\"2\" data-kid=\"52\"></circle>\n                <path class=\"branch-path\" d=\"M106,600 Q120,590 140,600\" data-kid=\"53\"></path>\n              </g>\n            </svg>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mb-32\" data-kid=\"54\">\n      <span class=\"section-label\" data-kid=\"55\">Interdisciplinary Mapping</span>\n      <h2 class=\"font-display text-4xl mb-12\" data-kid=\"56\">The Bio Bridge</h2>\n      \n      <div class=\"card p-0 overflow-hidden\" id=\"bio-bridge-card\" data-kid=\"57\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2\" data-kid=\"58\">\n          <div class=\"p-8 border-r border-[var(--color-border)]\" data-kid=\"59\">\n            <h4 class=\"text-xs uppercase tracking-widest text-[var(--color-text-muted)] mb-8\" data-kid=\"60\">Concept Transfer</h4>\n            <div class=\"space-y-4\" data-kid=\"61\">\n              <div class=\"bio-bridge-item tonometry-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] cursor-pointer\" data-id=\"1\" data-kid=\"62\">\n                <div class=\"flex flex-col\" data-kid=\"63\">\n                  <span class=\"font-italic-serif text-white\" data-kid=\"64\">Signal Processing</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"65\">Noise filtration & Sampling</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--color-vitality)] transition-colors\" data-kid=\"66\"></i>\n              </div>\n              <div class=\"bio-bridge-item tonometry-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] cursor-pointer\" data-id=\"2\" data-kid=\"67\">\n                <div class=\"flex flex-col\" data-kid=\"68\">\n                  <span class=\"font-italic-serif text-white\" data-kid=\"69\">Homeostasis</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"70\">Self-regulation & Feedback</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--color-vitality)] transition-colors\" data-kid=\"71\"></i>\n              </div>\n              <div class=\"bio-bridge-item tonometry-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] cursor-pointer\" data-id=\"3\" data-kid=\"72\">\n                <div class=\"flex flex-col\" data-kid=\"73\">\n                  <span class=\"font-italic-serif text-white\" data-kid=\"74\">Metabolic Pathways</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"75\">Energy & Resource Orchestration</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--color-vitality)] transition-colors\" data-kid=\"76\"></i>\n              </div>\n            </div>\n          </div>\n          \n          <div class=\"p-8 bg-white/[0.01] flex items-center justify-center relative overflow-hidden\" data-kid=\"77\">\n            <div class=\"relative w-full aspect-square max-w-[300px]\" data-kid=\"78\">\n              <div class=\"absolute inset-0 flex items-center justify-center\" data-kid=\"79\">\n                <div class=\"dna-3d-container w-24 h-24 rounded-full border border-white/5 bg-white/[0.02] flex items-center justify-center shadow-lg\" data-kid=\"80\">\n                  <i class=\"ti ti-dna text-3xl text-[var(--color-accent)]\" data-kid=\"81\"></i>\n                </div>\n              </div>\n              <svg class=\"absolute inset-0 w-full h-full overflow-visible\" viewBox=\"0 0 300 300\" data-kid=\"82\">\n                <path class=\"connector-path\" data-id=\"1\" d=\"M100,150 C50,150 50,50 220,50\" stroke=\"white\" stroke-width=\"1\" fill=\"none\" opacity=\"0.1\" stroke-dasharray=\"4 4\" data-kid=\"83\"></path>\n                <path class=\"connector-path\" data-id=\"2\" d=\"M100,150 C50,150 50,150 220,150\" stroke=\"white\" stroke-width=\"1\" fill=\"none\" opacity=\"0.1\" stroke-dasharray=\"4 4\" data-kid=\"84\"></path>\n                <path class=\"connector-path\" data-id=\"3\" d=\"M100,150 C50,150 50,250 220,250\" stroke=\"white\" stroke-width=\"1\" fill=\"none\" opacity=\"0.1\" stroke-dasharray=\"4 4\" data-kid=\"85\"></path>\n              </svg>\n              \n              <div class=\"absolute top-[35px] right-0 flex items-center gap-3\" data-kid=\"86\"><div class=\"w-8 h-8 rounded-lg bg-surface-raised border border-white/10 flex items-center justify-center\" data-kid=\"87\"><i class=\"ti ti-wave-square text-xs\" data-kid=\"88\"></i></div><span class=\"text-xs font-display\" data-kid=\"89\">Event Streaming</span></div>\n              <div class=\"absolute top-[135px] right-0 flex items-center gap-3\" data-kid=\"90\"><div class=\"w-8 h-8 rounded-lg bg-surface-raised border border-white/10 flex items-center justify-center\" data-kid=\"91\"><i class=\"ti ti-arrows-maximize text-xs\" data-kid=\"92\"></i></div><span class=\"text-xs font-display\" data-kid=\"93\">Autoscaling</span></div>\n              <div class=\"absolute bottom-[35px] right-0 flex items-center gap-3\" data-kid=\"94\"><div class=\"w-8 h-8 rounded-lg bg-surface-raised border border-white/10 flex items-center justify-center\" data-kid=\"95\"><i class=\"ti ti-stack-2 text-xs\" data-kid=\"96\"></i></div><span class=\"text-xs font-display\" data-kid=\"97\">Data Pipelines</span></div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mb-32\" data-kid=\"98\">\n      <span class=\"section-label\" data-kid=\"99\">Core Engineering Mindset</span>\n      <h2 class=\"font-display text-4xl mb-12\" data-kid=\"100\">Core Principles</h2>\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"101\">\n        <div class=\"card flex flex-col items-start h-full group\" data-kid=\"102\">\n          <svg class=\"vein-overlay\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"103\">\n             <path class=\"vein-path\" d=\"M10,10 Q30,50 0,90 M10,10 Q50,30 90,10\" data-kid=\"104\"></path>\n          </svg>\n          <div class=\"w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-8 border border-accent/20 transition-transform duration-500 group-hover:scale-110\" data-kid=\"105\">\n            <i class=\"ti ti-microscope text-xl text-[var(--color-accent)]\" data-kid=\"106\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"107\">Precision-First</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"108\">Applying clinical-grade attention to detail in every line of code and infrastructure configuration.</p>\n        </div>\n        <div class=\"card flex flex-col items-start h-full group\" data-kid=\"109\">\n          <svg class=\"vein-overlay\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"110\">\n             <path class=\"vein-path\" d=\"M50,0 Q60,50 50,100 M20,50 Q50,40 80,50\" data-kid=\"111\"></path>\n          </svg>\n          <div class=\"w-12 h-12 rounded-xl bg-vitality/10 flex items-center justify-center mb-8 border border-vitality/20 transition-transform duration-500 group-hover:scale-110\" data-kid=\"112\">\n            <i class=\"ti ti-refresh text-xl text-[var(--color-vitality)]\" data-kid=\"113\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"114\">Adaptive Design</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"115\">Building systems that embrace failure as a signal for self-correction, much like biological organisms.</p>\n        </div>\n        <div class=\"card flex flex-col items-start h-full group\" data-kid=\"116\">\n          <svg class=\"vein-overlay\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\" data-kid=\"117\">\n             <path class=\"vein-path\" d=\"M0,0 L100,100 M0,100 L100,0\" data-kid=\"118\"></path>\n          </svg>\n          <div class=\"w-12 h-12 rounded-xl bg-teal-400/10 flex items-center justify-center mb-8 border border-teal-400/20 transition-transform duration-500 group-hover:scale-110\" data-kid=\"119\">\n            <i class=\"ti ti-server text-xl text-teal-400\" data-kid=\"120\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"121\">Systemic Scalability</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"122\">Understanding the interconnected nature of services to ensure growth doesn't compromise stability.</p>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mb-32\" data-kid=\"123\">\n      <div class=\"text-center\" data-kid=\"124\">\n        <span class=\"section-label\" data-kid=\"125\">Curiosities & Explorations</span>\n        <h2 class=\"font-italic-serif text-4xl text-white mb-12\" data-kid=\"126\">Interests</h2>\n        <div class=\"flex flex-wrap justify-center gap-4 max-w-3xl mx-auto\" data-kid=\"127\">\n          <div class=\"interest-pill\" data-name=\"Machine Learning\" data-kid=\"128\">Machine Learning</div>\n          <div class=\"interest-pill\" data-name=\"Genomics\" data-kid=\"129\">Genomics</div>\n          <div class=\"interest-pill\" data-name=\"Distributed Systems\" data-kid=\"130\">Distributed Systems</div>\n          <div class=\"interest-pill\" data-name=\"Analog Synthesis\" data-kid=\"131\">Analog Synthesis</div>\n          <div class=\"interest-pill\" data-name=\"Computational Biology\" data-kid=\"132\">Computational Biology</div>\n          <div class=\"interest-pill\" data-name=\"Platform Engineering\" data-kid=\"133\">Platform Engineering</div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"max-w-6xl mx-auto px-6 py-12 border-t border-[var(--color-border)] flex justify-between items-center text-[10px] tracking-widest text-[var(--color-text-muted)] uppercase font-display\" data-kid=\"134\">\n    <div data-kid=\"135\">&copy; 2026 Esteban</div>\n    <div class=\"flex gap-8\" data-kid=\"136\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"137\">GitHub</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"138\">LinkedIn</a>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"139\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"140\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js\" data-kid=\"141\"></script>\n\n<script data-kid=\"142\">\n  gsap.registerPlugin(ScrollTrigger, Draggable);\n\n  // 1. Mycelium Grid Effect\n  const canvas = document.getElementById('mycelium-canvas');\n  const ctx = canvas.getContext('2d');\n  let width, height;\n  let lines = [];\n\n  function resize() {\n    width = canvas.width = window.innerWidth;\n    height = canvas.height = window.innerHeight;\n  }\n  window.addEventListener('resize', resize);\n  resize();\n\n  window.addEventListener('mousemove', (e) => {\n    if (Math.random() > 0.8) {\n      lines.push({\n        x: e.clientX,\n        y: e.clientY,\n        angle: Math.random() * Math.PI * 2,\n        length: 0,\n        maxLength: 40 + Math.random() * 40,\n        life: 1,\n        color: Math.random() > 0.5 ? '#c8bfff' : '#d9f99d'\n      });\n    }\n  });\n\n  function updateMycelium() {\n    ctx.clearRect(0, 0, width, height);\n    lines.forEach((l, i) => {\n      ctx.beginPath();\n      ctx.moveTo(l.x, l.y);\n      l.length += 2;\n      const endX = l.x + Math.cos(l.angle) * l.length;\n      const endY = l.y + Math.sin(l.angle) * l.length;\n      ctx.lineTo(endX, endY);\n      ctx.strokeStyle = l.color;\n      ctx.globalAlpha = l.life * 0.2;\n      ctx.stroke();\n      l.life -= 0.01;\n      if (l.life <= 0) lines.splice(i, 1);\n    });\n    requestAnimationFrame(updateMycelium);\n  }\n  updateMycelium();\n\n  // 2. Helix Scroll Interaction (Velocity & Sprouting)\n  let helixStroke = 2;\n  const helixPath = document.getElementById('helix-path');\n  \n  gsap.to(helixPath, {\n    strokeDashoffset: 0,\n    ease: 'none',\n    scrollTrigger: {\n      trigger: '#helix-svg',\n      start: 'top 60%',\n      end: 'bottom 40%',\n      scrub: 0.5,\n      onUpdate: (self) => {\n        const vel = Math.abs(self.getVelocity());\n        const targetWidth = 2 + (vel / 200);\n        gsap.to(helixPath, { strokeWidth: targetWidth, duration: 0.2 });\n      }\n    }\n  });\n\n  // Milestone Sprouting\n  const groups = document.querySelectorAll('.helix-group');\n  const texts = document.querySelectorAll('.milestone-text');\n  \n  texts.forEach((text, i) => {\n    ScrollTrigger.create({\n      trigger: text,\n      start: 'top 70%',\n      end: 'bottom 70%',\n      onEnter: () => {\n        gsap.to(text, { opacity: 1, x: 10, duration: 0.5 });\n        gsap.to(groups[i].querySelector('.branch-path'), { opacity: 1, strokeDashoffset: 0, duration: 0.8, ease: 'power2.out' });\n      },\n      onLeaveBack: () => {\n        gsap.to(text, { opacity: 0.3, x: 0, duration: 0.5 });\n        gsap.to(groups[i].querySelector('.branch-path'), { opacity: 0, strokeDashoffset: 100, duration: 0.5 });\n      }\n    });\n  });\n\n  // 3. Bio Bridge Magnetic Tonometry\n  const bridgeItems = document.querySelectorAll('.tonometry-item');\n  document.getElementById('bio-bridge-card').addEventListener('mousemove', (e) => {\n    const rect = e.currentTarget.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n\n    bridgeItems.forEach(item => {\n      const itemRect = item.getBoundingClientRect();\n      const ix = itemRect.left + itemRect.width / 2 - rect.left;\n      const iy = itemRect.top + itemRect.height / 2 - rect.top;\n      const dx = mx - ix;\n      const dy = my - iy;\n      const dist = Math.sqrt(dx*dx + dy*dy);\n      \n      if (dist < 200) {\n        const power = (200 - dist) / 200;\n        gsap.to(item, {\n          rotateY: dx * 0.1 * power,\n          rotateX: -dy * 0.1 * power,\n          z: 20 * power,\n          duration: 0.2\n        });\n      } else {\n        gsap.to(item, { rotateY: 0, rotateX: 0, z: 0, duration: 0.5 });\n      }\n    });\n  });\n\n  // 4. Draggable 3D DNA\n  Draggable.create('.dna-3d-container', {\n    type: 'rotation',\n    onDrag: function() {\n       gsap.set(this.target, { rotateY: this.rotation });\n    }\n  });\n\n  // 5. Fractal Veins Animation\n  document.querySelectorAll('.card').forEach(card => {\n    const vein = card.querySelector('.vein-path');\n    if (!vein) return;\n    card.addEventListener('mouseenter', () => {\n      gsap.to(vein, { strokeDashoffset: 0, duration: 1.5, ease: 'power2.inOut' });\n    });\n    card.addEventListener('mouseleave', () => {\n      gsap.to(vein, { strokeDashoffset: 200, duration: 1 });\n    });\n  });\n\n  // 6. Synaptic Interest Connections\n  const synapseSvg = document.getElementById('synapse-svg');\n  let activePills = [];\n\n  document.querySelectorAll('.interest-pill').forEach(pill => {\n    pill.addEventListener('click', (e) => {\n      pill.classList.toggle('is-active');\n      const rect = pill.getBoundingClientRect();\n      const center = { x: rect.left + rect.width/2, y: rect.top + rect.height/2 };\n      \n      if (pill.classList.contains('is-active')) {\n        activePills.push({ el: pill, pos: center });\n        if (activePills.length >= 2) {\n          const p1 = activePills[activePills.length - 2].pos;\n          const p2 = activePills[activePills.length - 1].pos;\n          drawSynapse(p1, p2);\n        }\n      } else {\n        activePills = activePills.filter(p => p.el !== pill);\n      }\n    });\n  });\n\n  function drawSynapse(p1, p2) {\n    const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');\n    const cp1x = p1.x + (p2.x - p1.x) / 2;\n    const cp1y = p1.y - 50;\n    const d = `M${p1.x},${p1.y} Q${cp1x},${cp1y} ${p2.x},${p2.y}`;\n    \n    path.setAttribute('d', d);\n    path.setAttribute('stroke', '#d9f99d');\n    path.setAttribute('stroke-width', '1.5');\n    path.setAttribute('fill', 'none');\n    path.setAttribute('stroke-dasharray', '300');\n    path.setAttribute('stroke-dashoffset', '300');\n    path.style.filter = 'blur(1px)';\n    \n    synapseSvg.appendChild(path);\n    \n    gsap.to(path, {\n      strokeDashoffset: 0,\n      duration: 0.6,\n      ease: 'power2.out',\n      onComplete: () => {\n        gsap.to(path, { opacity: 0, duration: 1.5, delay: 0.5, onComplete: () => path.remove() });\n      }\n    });\n  }\n</script>",
      "comments": [],
      "created": "2026-06-22T00:31:56.098607+00:00",

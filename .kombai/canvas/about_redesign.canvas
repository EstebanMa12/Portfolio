      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --font-display: 'Inter', system-ui, sans-serif;\n    --font-serif: 'EB Garamond', serif;\n    --font-sans: 'Inter', sans-serif;\n    --font-mono: 'JetBrains Mono', monospace;\n    \n    --color-bg: #0a0a0b;\n    --color-surface: #141416;\n    --color-surface-raised: #1c1c1f;\n    --color-border: rgba(255, 255, 255, 0.08);\n    --color-accent: #c8bfff;\n    --color-vitality: #d9f99d;\n    --terminal-green: #4ade80;\n    --color-text-primary: #fafafa;\n    --color-text-secondary: #a1a1aa;\n    --color-text-muted: #71717a;\n    --spacing-section-gap: 96px;\n  }\n\n  ::selection {\n    background: var(--terminal-green);\n    color: #000;\n  }\n\n  body {\n    background-color: var(--color-bg);\n    color: var(--color-text-primary);\n    font-family: var(--font-sans);\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .section-label {\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: var(--color-text-secondary);\n    margin-bottom: 0.75rem;\n    display: inline-block;\n  }\n\n  .card {\n    background: var(--color-surface);\n    border: 1px solid var(--color-border);\n    border-radius: 16px;\n    padding: 2rem;\n    position: relative;\n    overflow: hidden;\n    opacity: 0;\n  }\n\n  /* Glitch Entrance */\n  .glitch-active {\n    animation: glitch-in 0.4s steps(2, end) forwards;\n  }\n\n  @keyframes glitch-in {\n    0% { transform: translate(0) skew(0); clip-path: inset(0 0 0 0); opacity: 0; }\n    10% { transform: translate(-5px) skew(5deg); clip-path: inset(20% 0 30% 0); opacity: 1; }\n    20% { transform: translate(5px) skew(-5deg); clip-path: inset(60% 0 10% 0); }\n    30% { transform: translate(-2px) skew(2deg); clip-path: inset(10% 0 80% 0); }\n    100% { transform: translate(0) skew(0); clip-path: inset(0 0 0 0); opacity: 1; }\n  }\n\n  /* Scanline Hover */\n  .scanline {\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 4px;\n    background: linear-gradient(to bottom, transparent, var(--terminal-green), transparent);\n    opacity: 0;\n    pointer-events: none;\n    z-index: 10;\n  }\n\n  .card:hover .scanline {\n    animation: scan 1.5s linear infinite;\n    opacity: 0.4;\n  }\n\n  @keyframes scan {\n    from { transform: translateY(-100%); }\n    to { transform: translateY(500px); }\n  }\n\n  /* Terminal Elements */\n  .terminal-cursor {\n    display: inline-block;\n    width: 0.6em;\n    height: 1.1em;\n    background: var(--terminal-green);\n    vertical-align: middle;\n    margin-left: 2px;\n    animation: blink 0.8s step-end infinite;\n  }\n\n  @keyframes blink { 50% { opacity: 0; } }\n\n  #terminal-tooltip {\n    position: fixed;\n    pointer-events: none;\n    background: #000;\n    border: 1px solid var(--terminal-green);\n    padding: 12px;\n    font-family: var(--font-mono);\n    font-size: 11px;\n    color: var(--terminal-green);\n    z-index: 1000;\n    display: none;\n    box-shadow: 0 0 30px rgba(74, 222, 128, 0.15);\n    border-radius: 4px;\n  }\n\n  .font-display { font-family: var(--font-display); font-weight: 600; letter-spacing: -0.02em; }\n  .font-italic-serif { font-family: var(--font-serif); font-style: italic; }\n\n  .about-page-grid {\n    position: absolute;\n    inset: 0;\n    background-image: linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),\n                      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);\n    background-size: 56px 56px;\n    mask-image: radial-gradient(ellipse 85% 65% at 50% 20%, black 15%, transparent 70%);\n    pointer-events: none;\n  }\n\n  .helix-path {\n    stroke: var(--color-accent);\n    stroke-width: 2;\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n  }\n\n  .node-flash {\n    position: absolute;\n    width: 20px;\n    height: 20px;\n    background: white;\n    border-radius: 50%;\n    filter: blur(10px);\n    opacity: 0;\n    transform: translate(-50%, -50%);\n  }\n\n  .interest-pill {\n    padding: 0.625rem 1rem;\n    border-radius: 9999px;\n    background: var(--color-surface-raised);\n    border: 1px solid var(--color-border);\n    font-size: 0.8125rem;\n    color: var(--color-text-primary);\n    transition: all 0.3s ease;\n    cursor: default;\n    font-family: var(--font-mono);\n  }\n\n  .interest-pill:hover {\n    border-color: var(--terminal-green);\n    color: var(--terminal-green);\n    box-shadow: 0 0 15px rgba(74, 222, 128, 0.2);\n  }\n</style>\n\n<div id=\"terminal-tooltip\" data-kid=\"1\"></div>\n\n<div class=\"relative min-h-screen\" data-kid=\"2\">\n  <div class=\"fixed inset-0 z-0\" data-kid=\"3\">\n    <div class=\"about-page-grid\" data-kid=\"4\"></div>\n  </div>\n\n  <main class=\"relative z-10 max-w-6xl mx-auto px-6 py-[var(--spacing-section-gap)]\" data-kid=\"5\">\n    <header class=\"mb-32\" data-kid=\"6\">\n      <div class=\"max-w-3xl\" data-kid=\"7\">\n        <span class=\"section-label\" data-kid=\"8\">> SYSTEM_ABOUT_V2</span>\n        <h1 class=\"font-display text-5xl md:text-7xl leading-[1.1] mb-8\" id=\"hero-title\" data-kid=\"9\">\n          The Biological Blueprint of Software Architecture.\n        </h1>\n        <p class=\"text-xl text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"10\">\n          Synthesizing scientific precision with cloud-native engineering. My background in <span class=\"font-italic-serif text-white\" data-kid=\"11\">Bioengineering</span> provides a unique vantage point on system resilience and homeostasis.\n        </p>\n      </div>\n    </header>\n\n    <section class=\"mb-32\" data-kid=\"12\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-12 items-start\" data-kid=\"13\">\n        <div class=\"lg:col-span-6 space-y-12\" data-kid=\"14\">\n          <div data-kid=\"15\">\n            <span class=\"section-label\" data-kid=\"16\">Evolution Path</span>\n            <h2 class=\"font-display text-4xl mb-6\" data-kid=\"17\">The Career Helix</h2>\n          </div>\n          <div class=\"space-y-8 relative\" data-kid=\"18\">\n            <div class=\"milestone-text opacity-50 transition-opacity duration-500\" data-index=\"0\" data-kid=\"19\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"20\">01. Physiological Foundations</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"21\">Decoding bio-signals and modeling homeostatic feedback loops in clinical environments.</p>\n            </div>\n            <div class=\"milestone-text opacity-50 transition-opacity duration-500\" data-index=\"1\" data-kid=\"22\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"23\">02. Data Translation</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"24\">Scaling clinical research pipelines and orchestrating medical datasets.</p>\n            </div>\n            <div class=\"milestone-text opacity-50 transition-opacity duration-500\" data-index=\"2\" data-kid=\"25\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"26\">03. Backend Evolution</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"27\">Pivoting logic from biological cells to distributed software cells.</p>\n            </div>\n            <div class=\"milestone-text opacity-50 transition-opacity duration-500\" data-index=\"3\" data-kid=\"28\">\n              <h4 class=\"font-display text-xl text-white mb-2\" data-kid=\"29\">04. Platform Architecture</h4>\n              <p class=\"text-sm text-[var(--color-text-muted)]\" data-kid=\"30\">Building resilient, self-healing infrastructures at scale.</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"lg:col-span-6 sticky top-24 h-[600px] flex items-center justify-center\" data-kid=\"31\">\n          <div class=\"relative w-full h-full max-w-[400px]\" data-kid=\"32\">\n            <div id=\"flash-overlay\" class=\"node-flash\" data-kid=\"33\"></div>\n            <svg viewBox=\"0 0 200 600\" class=\"w-full h-full overflow-visible\" data-kid=\"34\">\n              <path id=\"helix-path\" class=\"helix-path\" d=\"M100,0 C150,75 50,125 100,200 C150,275 50,325 100,400 C150,475 50,525 100,600\" fill=\"none\" data-kid=\"35\"></path>\n              <circle cx=\"100\" cy=\"0\" r=\"4\" fill=\"var(--color-accent)\" class=\"milestone-node\" data-idx=\"0\" data-kid=\"36\"></circle>\n              <circle cx=\"100\" cy=\"200\" r=\"4\" fill=\"var(--color-accent)\" class=\"milestone-node\" data-idx=\"1\" data-kid=\"37\"></circle>\n              <circle cx=\"100\" cy=\"400\" r=\"4\" fill=\"var(--color-accent)\" class=\"milestone-node\" data-idx=\"2\" data-kid=\"38\"></circle>\n              <circle cx=\"100\" cy=\"600\" r=\"4\" fill=\"var(--color-accent)\" class=\"milestone-node\" data-idx=\"3\" data-kid=\"39\"></circle>\n            </svg>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mb-32\" data-kid=\"40\">\n      <span class=\"section-label\" data-kid=\"41\">Interdisciplinary Mapping</span>\n      <h2 class=\"font-display text-4xl mb-12\" data-kid=\"42\">The Bio Bridge</h2>\n      <div class=\"card p-0 overflow-hidden glitch-item\" data-kid=\"43\">\n        <div class=\"scanline\" data-kid=\"44\"></div>\n        <div class=\"grid grid-cols-1 md:grid-cols-2\" data-kid=\"45\">\n          <div class=\"p-8 border-r border-[var(--color-border)]\" data-kid=\"46\">\n            <h4 class=\"text-xs uppercase tracking-widest text-[var(--color-text-muted)] mb-8\" data-kid=\"47\">Concept Transfer</h4>\n            <div class=\"space-y-4\" data-kid=\"48\">\n              <div class=\"bio-bridge-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] transition-colors cursor-pointer\" data-id=\"1\" data-logs=\"> Noise filtration... > Sampling... > STATUS: OK\" data-kid=\"49\">\n                <div class=\"flex flex-col\" data-kid=\"50\">\n                  <span class=\"font-italic-serif text-white\" data-kid=\"51\">Signal Processing</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"52\">Noise filtration & Sampling</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--terminal-green)] transition-colors\" data-kid=\"53\"></i>\n              </div>\n              <div class=\"bio-bridge-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] transition-colors cursor-pointer\" data-id=\"2\" data-logs=\"> Loading feedback... > Regulating... > STATUS: STABLE\" data-kid=\"54\">\n                <div class=\"flex flex-col\" data-kid=\"55\">\n                  <span class=\"font-italic-serif text-white\" data-kid=\"56\">Homeostasis</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"57\">Self-regulation & Feedback</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--terminal-green)] transition-colors\" data-kid=\"58\"></i>\n              </div>\n              <div class=\"bio-bridge-item group flex items-center justify-between p-4 rounded-xl hover:bg-white/[0.03] transition-colors cursor-pointer\" data-id=\"3\" data-logs=\"> Mapping paths... > Orchestrating... > STATUS: ACTIVE\" data-kid=\"59\">\n                <div class=\"flex flex-col\" data-kid=\"60\">\n                  <span class=\"font-italic-serif text-white\" data-kid=\"61\">Metabolic Pathways</span>\n                  <span class=\"text-xs text-[var(--color-text-muted)] mt-1\" data-kid=\"62\">Energy Orchestration</span>\n                </div>\n                <i class=\"ti ti-arrow-right text-[var(--color-text-muted)] group-hover:text-[var(--terminal-green)] transition-colors\" data-kid=\"63\"></i>\n              </div>\n            </div>\n          </div>\n          <div class=\"p-8 bg-white/[0.01] flex items-center justify-center relative\" data-kid=\"64\">\n            <i class=\"ti ti-dna text-4xl text-[var(--color-accent)] opacity-20\" data-kid=\"65\"></i>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mb-32\" data-kid=\"66\">\n      <span class=\"section-label\" data-kid=\"67\">Core Engineering Mindset</span>\n      <h2 class=\"font-display text-4xl mb-12\" data-kid=\"68\">Core Principles</h2>\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"69\">\n        <div class=\"card glitch-item\" data-kid=\"70\">\n          <div class=\"scanline\" data-kid=\"71\"></div>\n          <div class=\"w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-8 border border-accent/20\" data-kid=\"72\">\n            <i class=\"ti ti-microscope text-xl text-[var(--color-accent)]\" data-kid=\"73\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"74\">Precision-First</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"75\">Applying clinical-grade attention to detail in every configuration.</p>\n        </div>\n        <div class=\"card glitch-item\" data-kid=\"76\">\n          <div class=\"scanline\" data-kid=\"77\"></div>\n          <div class=\"w-12 h-12 rounded-xl bg-vitality/10 flex items-center justify-center mb-8 border border-vitality/20\" data-kid=\"78\">\n            <i class=\"ti ti-refresh text-xl text-[var(--color-vitality)]\" data-kid=\"79\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"80\">Adaptive Design</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"81\">Building systems that embrace failure as a signal for self-correction.</p>\n        </div>\n        <div class=\"card glitch-item\" data-kid=\"82\">\n          <div class=\"scanline\" data-kid=\"83\"></div>\n          <div class=\"w-12 h-12 rounded-xl bg-teal-400/10 flex items-center justify-center mb-8 border border-teal-400/20\" data-kid=\"84\">\n            <i class=\"ti ti-server text-xl text-teal-400\" data-kid=\"85\"></i>\n          </div>\n          <h4 class=\"font-display text-2xl text-white mb-4\" data-kid=\"86\">Systemic Scalability</h4>\n          <p class=\"text-[var(--color-text-secondary)] leading-relaxed\" data-kid=\"87\">Understanding the interconnected nature of services to ensure growth.</p>\n        </div>\n      </div>\n    </section>\n\n    <section class=\"mb-32\" data-kid=\"88\">\n      <div class=\"text-center\" data-kid=\"89\">\n        <span class=\"section-label\" data-kid=\"90\">Curiosities</span>\n        <h2 class=\"font-italic-serif text-4xl text-white mb-12\" data-kid=\"91\">Interests</h2>\n        <div class=\"flex flex-wrap justify-center gap-4 max-w-3xl mx-auto\" data-kid=\"92\">\n          <div class=\"interest-pill\" data-kid=\"93\">Machine Learning</div>\n          <div class=\"interest-pill\" data-kid=\"94\">Genomics</div>\n          <div class=\"interest-pill\" data-kid=\"95\">Distributed Systems</div>\n          <div class=\"interest-pill\" data-kid=\"96\">Analog Synthesis</div>\n          <div class=\"interest-pill\" data-kid=\"97\">Computational Biology</div>\n          <div class=\"interest-pill\" data-kid=\"98\">Platform Engineering</div>\n        </div>\n      </div>\n    </section>\n  </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"99\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"100\"></script>\n<script data-kid=\"101\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // 1. Hero Terminal Typing\n  const heroTitle = document.getElementById('hero-title');\n  const originalHeroText = heroTitle.innerText;\n  heroTitle.innerHTML = '<span class=\"terminal-cursor\"></span>';\n  \n  let charIdx = 0;\n  const typeInterval = setInterval(() => {\n    if (charIdx < originalHeroText.length) {\n      heroTitle.insertAdjacentText('beforeend', originalHeroText[charIdx]);\n      heroTitle.appendChild(heroTitle.querySelector('.terminal-cursor'));\n      charIdx++;\n    } else {\n      clearInterval(typeInterval);\n      setTimeout(() => heroTitle.querySelector('.terminal-cursor').remove(), 3000);\n    }\n  }, 40);\n\n  // 2. Helix ECG Trace\n  gsap.to('#helix-path', {\n    strokeDashoffset: 0,\n    ease: 'none',\n    scrollTrigger: {\n      trigger: '#helix-path',\n      start: 'top 60%',\n      end: 'bottom 40%',\n      scrub: 0.1 // Jagged response\n    }\n  });\n\n  document.querySelectorAll('.milestone-node').forEach((node, i) => {\n    ScrollTrigger.create({\n      trigger: node,\n      start: 'top center',\n      onEnter: () => {\n        gsap.to(node, { fill: 'white', r: 8, duration: 0.1, yoyo: true, repeat: 1 });\n        gsap.fromTo('#flash-overlay', { opacity: 0.8, x: node.getAttribute('cx'), y: node.getAttribute('cy') }, { opacity: 0, duration: 0.5 });\n      }\n    });\n  });\n\n  // 3. Glitch Entrance\n  gsap.utils.toArray('.glitch-item').forEach(el => {\n    ScrollTrigger.create({\n      trigger: el,\n      start: 'top 85%',\n      onEnter: () => el.classList.add('glitch-active')\n    });\n  });\n\n  // 4. Bio Bridge Terminal Tooltips\n  const tooltip = document.getElementById('terminal-tooltip');\n  document.querySelectorAll('.bio-bridge-item').forEach(item => {\n    item.addEventListener('mouseenter', (e) => {\n      tooltip.style.display = 'block';\n      tooltip.innerHTML = '';\n      const logs = item.dataset.logs.split(' > ');\n      logs.forEach((log, i) => {\n        setTimeout(() => {\n          tooltip.innerHTML += `<div>> ${log}</div>`;\n        }, i * 150);\n      });\n    });\n    item.addEventListener('mousemove', (e) => {\n      tooltip.style.left = (e.clientX + 15) + 'px';\n      tooltip.style.top = (e.clientY + 15) + 'px';\n    });\n    item.addEventListener('mouseleave', () => tooltip.style.display = 'none');\n  });\n\n  // 5. Interest Hex Decoding\n  const hexChars = '0123456789ABCDEF';\n  document.querySelectorAll('.interest-pill').forEach(pill => {\n    const original = pill.innerText;\n    pill.addEventListener('mouseenter', () => {\n      let iterations = 0;\n      const interval = setInterval(() => {\n        pill.innerText = original.split('').map((char, index) => {\n          if (index < iterations) return original[index];\n          return hexChars[Math.floor(Math.random() * 16)];\n        }).join('');\n        if (iterations >= original.length) clearInterval(interval);\n        iterations += 1/2;\n      }, 30);\n    });\n  });\n</script>",

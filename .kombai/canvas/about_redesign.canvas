      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --theme-bg: #0a0a0b;\n    --theme-surface: #141416;\n    --theme-accent: #c8bfff;\n    --theme-teal: #2dd4bf;\n    --text-primary: #ffffff;\n    --text-secondary: #88888b;\n    --text-muted: #52525b;\n    --grid-color: rgba(255, 255, 255, 0.03);\n  }\n\n  body {\n    background-color: var(--theme-bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  .font-mono { font-family: 'JetBrains Mono', monospace; }\n\n  /* Technical Grid & Scanning Line */\n  .grid-bg {\n    position: fixed;\n    inset: 0;\n    background-image: radial-gradient(circle, var(--grid-color) 1px, transparent 1px);\n    background-size: 40px 40px;\n    z-index: -1;\n    pointer-events: none;\n  }\n\n  .scanning-laser {\n    position: fixed;\n    top: -100px;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background: linear-gradient(90deg, transparent, var(--theme-teal), transparent);\n    box-shadow: 0 0 15px var(--theme-teal);\n    z-index: 10;\n    opacity: 0.3;\n    pointer-events: none;\n  }\n\n  .grain {\n    position: fixed;\n    inset: 0;\n    background-image: url('https://grainy-gradients.vercel.app/noise.svg');\n    opacity: 0.05;\n    pointer-events: none;\n    z-index: 50;\n  }\n\n  /* Sticky Left Sidebar Title */\n  .vertical-title-container {\n    position: sticky;\n    top: 0;\n    height: 100vh;\n    width: 80px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border-right: 1px solid rgba(255, 255, 255, 0.05);\n  }\n\n  .vertical-title {\n    transform: rotate(-90deg);\n    white-space: nowrap;\n    text-transform: uppercase;\n    letter-spacing: 0.5em;\n    font-size: 12px;\n    font-weight: 700;\n    color: var(--text-muted);\n  }\n\n  /* Evolution Timeline Styles */\n  .timeline-line {\n    position: absolute;\n    left: 50%;\n    top: 0;\n    bottom: 0;\n    width: 2px;\n    background: var(--theme-surface);\n    transform: translateX(-50%);\n  }\n\n  .timeline-progress {\n    position: absolute;\n    left: 50%;\n    top: 0;\n    width: 2px;\n    background: linear-gradient(to bottom, var(--theme-teal), var(--theme-accent));\n    box-shadow: 0 0 10px rgba(45, 212, 191, 0.5);\n    transform: translateX(-50%);\n    height: 0%; /* Driven by scroll */\n  }\n\n  .diamond-node {\n    width: 16px;\n    height: 16px;\n    background: var(--theme-bg);\n    border: 2px solid var(--theme-teal);\n    transform: rotate(45deg);\n    position: relative;\n    z-index: 2;\n  }\n\n  /* Bio Bridge Table */\n  .bio-bridge-row:hover .bio-side { color: var(--text-muted); }\n  .bio-bridge-row:hover .tech-side { color: var(--theme-teal); text-shadow: 0 0 8px rgba(45, 212, 191, 0.4); }\n\n  .connector-curve {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n    transition: stroke-dashoffset 0.6s ease;\n  }\n  .bio-bridge-row:hover .connector-curve {\n    stroke-dashoffset: 0;\n  }\n\n</style>\n\n<div class=\"grid-bg\" data-kid=\"1\"></div>\n<div class=\"grain\" data-kid=\"2\"></div>\n<div class=\"scanning-laser\" id=\"laser\" data-kid=\"3\"></div>\n\n<div class=\"flex\" data-kid=\"4\">\n  \n  <aside class=\"hidden lg:flex vertical-title-container\" data-kid=\"5\">\n    <div class=\"vertical-title\" data-kid=\"6\">Engineering Narrative // 2018—2024</div>\n  </aside>\n\n  \n  <main class=\"flex-1 max-w-5xl mx-auto px-6 py-20 lg:py-32\" data-kid=\"7\">\n    \n    \n    <header class=\"mb-32\" data-kid=\"8\">\n      <div id=\"hero-reveal\" class=\"opacity-0\" data-kid=\"9\">\n        <span class=\"font-mono text-[10px] uppercase tracking-[0.3em] text-teal-400 mb-4 block\" data-kid=\"10\">System Initialization</span>\n        <h1 class=\"text-5xl md:text-7xl font-bold tracking-tight mb-8 leading-[0.9]\" data-kid=\"11\">\n          Synthesizing <br data-kid=\"12\">\n          <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-teal-400 to-indigo-400\" data-kid=\"13\">Complex Systems</span>\n        </h1>\n        <p class=\"text-xl text-zinc-400 max-w-2xl leading-relaxed\" data-kid=\"14\">\n          Former bioengineer turned software architect. I build scalable foundations where biological precision meets architectural robustness.\n        </p>\n      </div>\n    </header>\n\n    \n    <section class=\"mb-48 relative py-20\" data-kid=\"15\">\n      <div class=\"timeline-line\" data-kid=\"16\"></div>\n      <div class=\"timeline-progress\" id=\"progress-line\" data-kid=\"17\"></div>\n\n      <div class=\"space-y-32\" data-kid=\"18\">\n        \n        <div class=\"relative flex items-center justify-between\" data-kid=\"19\">\n          <div class=\"w-5/12 text-right pr-12 reveal-on-scroll\" data-kid=\"20\">\n            <h3 class=\"text-lg font-semibold text-teal-400 mb-2\" data-kid=\"21\">Bioengineering Origins</h3>\n            <p class=\"text-sm text-zinc-500\" data-kid=\"22\">Signal processing and cellular modeling in lab environments.</p>\n          </div>\n          <div class=\"diamond-node shadow-[0_0_15px_rgba(45,212,191,0.3)]\" data-kid=\"23\"></div>\n          <div class=\"w-5/12\" data-kid=\"24\"></div>\n        </div>\n\n        \n        <div class=\"relative flex items-center justify-between\" data-kid=\"25\">\n          <div class=\"w-5/12\" data-kid=\"26\"></div>\n          <div class=\"diamond-node border-white\" data-kid=\"27\"></div>\n          <div class=\"w-5/12 pl-12 reveal-on-scroll\" data-kid=\"28\">\n            <h3 class=\"text-lg font-semibold text-white mb-2\" data-kid=\"29\">The Digital Pivot</h3>\n            <p class=\"text-sm text-zinc-500\" data-kid=\"30\">Realizing that the tools used to model life were the lifeblood of modern industry.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"relative flex items-center justify-between\" data-kid=\"31\">\n          <div class=\"w-5/12 text-right pr-12 reveal-on-scroll\" data-kid=\"32\">\n            <h3 class=\"text-lg font-semibold text-indigo-400 mb-2\" data-kid=\"33\">Systems Architecture</h3>\n            <p class=\"text-sm text-zinc-500\" data-kid=\"34\">Distributed systems, platform engineering, and high-concurrency engines.</p>\n          </div>\n          <div class=\"diamond-node border-indigo-400\" data-kid=\"35\"></div>\n          <div class=\"w-5/12\" data-kid=\"36\"></div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-48\" data-kid=\"37\">\n      <div class=\"grid grid-cols-2 md:grid-cols-4 border-y border-white/5 py-12\" data-kid=\"38\">\n        <div class=\"px-8 border-r border-white/5 text-center md:text-left\" data-kid=\"39\">\n          <span class=\"font-mono text-[8px] uppercase tracking-widest text-zinc-500 block mb-2\" data-kid=\"40\">Exp. Years</span>\n          <div class=\"text-4xl font-mono font-bold\" data-kid=\"41\">6+</div>\n        </div>\n        <div class=\"px-8 border-r border-white/5 text-center md:text-left\" data-kid=\"42\">\n          <span class=\"font-mono text-[8px] uppercase tracking-widest text-zinc-500 block mb-2\" data-kid=\"43\">Production Projects</span>\n          <div class=\"text-4xl font-mono font-bold\" data-kid=\"44\">42</div>\n        </div>\n        <div class=\"px-8 border-r border-white/5 text-center md:text-left\" data-kid=\"45\">\n          <span class=\"font-mono text-[8px] uppercase tracking-widest text-zinc-500 block mb-2\" data-kid=\"46\">Tech Stack</span>\n          <div class=\"text-4xl font-mono font-bold\" data-kid=\"47\">18</div>\n        </div>\n        <div class=\"px-8 text-center md:text-left\" data-kid=\"48\">\n          <span class=\"font-mono text-[8px] uppercase tracking-widest text-zinc-500 block mb-2\" data-kid=\"49\">Specializations</span>\n          <div class=\"text-4xl font-mono font-bold\" data-kid=\"50\">4</div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-48\" data-kid=\"51\">\n      <div class=\"mb-12\" data-kid=\"52\">\n        <h2 class=\"text-2xl font-semibold mb-4\" data-kid=\"53\">Bio-Technical Bridge</h2>\n        <p class=\"text-zinc-500\" data-kid=\"54\">Mapping scientific principles to modern software architecture.</p>\n      </div>\n\n      <div class=\"space-y-px bg-white/5 border border-white/5 rounded-sm overflow-hidden\" data-kid=\"55\">\n        \n        <div class=\"bio-bridge-row grid grid-cols-2 bg-zinc-950 p-8 transition-colors duration-500 hover:bg-zinc-900 group relative\" data-kid=\"56\">\n          <div class=\"bio-side transition-colors duration-300\" data-kid=\"57\">\n            <span class=\"font-mono text-[9px] uppercase tracking-tighter text-zinc-600 block mb-1\" data-kid=\"58\">Source: Biology</span>\n            <div class=\"text-lg font-medium\" data-kid=\"59\">Signal Processing</div>\n          </div>\n          <div class=\"tech-side text-right transition-colors duration-300\" data-kid=\"60\">\n            <span class=\"font-mono text-[9px] uppercase tracking-tighter text-zinc-600 block mb-1\" data-kid=\"61\">Target: Software</span>\n            <div class=\"text-lg font-medium text-zinc-400\" data-kid=\"62\">Event Streaming & Pipelines</div>\n          </div>\n          <svg class=\"absolute inset-0 w-full h-full pointer-events-none opacity-20\" preserveAspectRatio=\"none\" data-kid=\"63\">\n             <path d=\"M 50% 0 L 50% 100%\" stroke=\"var(--theme-teal)\" stroke-width=\"0.5\" fill=\"none\" class=\"connector-curve\" data-kid=\"64\"></path>\n          </svg>\n        </div>\n\n        \n        <div class=\"bio-bridge-row grid grid-cols-2 bg-zinc-950 p-8 transition-colors duration-500 hover:bg-zinc-900 group\" data-kid=\"65\">\n          <div class=\"bio-side transition-colors duration-300\" data-kid=\"66\">\n            <span class=\"font-mono text-[9px] uppercase tracking-tighter text-zinc-600 block mb-1\" data-kid=\"67\">Source: Biology</span>\n            <div class=\"text-lg font-medium\" data-kid=\"68\">Genetic Sequences</div>\n          </div>\n          <div class=\"tech-side text-right transition-colors duration-300\" data-kid=\"69\">\n            <span class=\"font-mono text-[9px] uppercase tracking-tighter text-zinc-600 block mb-1\" data-kid=\"70\">Target: Software</span>\n            <div class=\"text-lg font-medium text-zinc-400\" data-kid=\"71\">Binary Data & Serialization</div>\n          </div>\n        </div>\n\n        \n        <div class=\"bio-bridge-row grid grid-cols-2 bg-zinc-950 p-8 transition-colors duration-500 hover:bg-zinc-900 group\" data-kid=\"72\">\n          <div class=\"bio-side transition-colors duration-300\" data-kid=\"73\">\n            <span class=\"font-mono text-[9px] uppercase tracking-tighter text-zinc-600 block mb-1\" data-kid=\"74\">Source: Biology</span>\n            <div class=\"text-lg font-medium\" data-kid=\"75\">Homeostasis</div>\n          </div>\n          <div class=\"tech-side text-right transition-colors duration-300\" data-kid=\"76\">\n            <span class=\"font-mono text-[9px] uppercase tracking-tighter text-zinc-600 block mb-1\" data-kid=\"77\">Target: Software</span>\n            <div class=\"text-lg font-medium text-zinc-400\" data-kid=\"78\">Auto-scaling & Resilience</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"grid grid-cols-1 md:grid-cols-2 gap-4\" data-kid=\"79\">\n      <div class=\"p-10 bg-zinc-950 border border-white/5 rounded-sm hover:border-teal-400/30 transition-all duration-500 group relative overflow-hidden\" data-kid=\"80\">\n        <div class=\"absolute top-0 left-0 w-1 h-full bg-teal-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-500\" data-kid=\"81\"></div>\n        <i class=\"ti ti-dna text-3xl text-teal-400 mb-6 block\" data-kid=\"82\"></i>\n        <h3 class=\"text-xl font-bold mb-4\" data-kid=\"83\">Biological Rigor</h3>\n        <p class=\"text-zinc-500 leading-relaxed\" data-kid=\"84\">Applying scientific observation and testing methodologies to code reliability and performance optimization.</p>\n      </div>\n      <div class=\"p-10 bg-zinc-950 border border-white/5 rounded-sm hover:border-indigo-400/30 transition-all duration-500 group relative overflow-hidden\" data-kid=\"85\">\n        <div class=\"absolute top-0 left-0 w-1 h-full bg-indigo-400 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-500\" data-kid=\"86\"></div>\n        <i class=\"ti ti-cpu text-3xl text-indigo-400 mb-6 block\" data-kid=\"87\"></i>\n        <h3 class=\"text-xl font-bold mb-4\" data-kid=\"88\">Architectural Logic</h3>\n        <p class=\"text-zinc-500 leading-relaxed\" data-kid=\"89\">Designing decoupled, observable, and modular infrastructures that thrive in high-scale environments.</p>\n      </div>\n    </section>\n\n  </main>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"90\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"91\"></script>\n<script data-kid=\"92\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initial Hero Animation\n  gsap.to(\"#hero-reveal\", {\n    opacity: 1,\n    y: -20,\n    duration: 1,\n    ease: \"power3.out\",\n    delay: 0.5\n  });\n\n  // Scanning Laser Animation\n  gsap.to(\"#laser\", {\n    top: \"100%\",\n    duration: 12,\n    repeat: -1,\n    ease: \"none\"\n  });\n\n  // Scroll Progress Timeline\n  gsap.to(\"#progress-line\", {\n    height: \"100%\",\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: \".timeline-line\",\n      start: \"top center\",\n      end: \"bottom center\",\n      scrub: true\n    }\n  });\n\n  // Reveal elements on scroll\n  document.querySelectorAll('.reveal-on-scroll').forEach(el => {\n    gsap.from(el, {\n      opacity: 0,\n      x: el.classList.contains('text-right') ? -30 : 30,\n      duration: 0.8,\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 85%\",\n        toggleActions: \"play none none reverse\"\n      }\n    });\n  });\n</script>",

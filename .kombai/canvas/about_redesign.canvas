      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&family=Inter:wght@400;500;600;700&display=swap');\n  \n  :root {\n    --theme-bg: #0a0a0b;\n    --theme-surface: #141416;\n    --color-accent: #c8bfff;\n    --color-vitality: #d9f99d;\n    --ambient-orb-1: rgba(200, 191, 255, 0.15);\n    --ambient-orb-2: rgba(45, 212, 191, 0.1);\n  }\n\n  body {\n    background-color: var(--theme-bg);\n    color: #e5e7eb;\n    margin: 0;\n    font-family: 'Inter', sans-serif;\n    overflow-x: hidden;\n  }\n\n  .font-serif { font-family: 'EB Garamond', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  .mesh-gradient {\n    background: radial-gradient(circle at 20% 30%, var(--ambient-orb-1) 0%, transparent 50%),\n                radial-gradient(circle at 80% 70%, var(--ambient-orb-2) 0%, transparent 50%);\n    filter: blur(80px);\n  }\n\n  .glass-card {\n    background: rgba(255, 255, 255, 0.03);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .hover-vitality:hover {\n    color: var(--color-vitality);\n    text-shadow: 0 0 15px rgba(217, 249, 157, 0.5);\n  }\n\n  .floating-orb {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(40px);\n    z-index: -1;\n    animation: float 20s infinite alternate ease-in-out;\n  }\n\n  @keyframes float {\n    from { transform: translate(0, 0) scale(1); }\n    to { transform: translate(50px, 100px) scale(1.2); }\n  }\n\n  .ripple {\n    position: absolute;\n    border: 1px solid var(--color-vitality);\n    border-radius: 50%;\n    transform: scale(0);\n    opacity: 0;\n    pointer-events: none;\n  }\n\n  @keyframes ripple-effect {\n    to { transform: scale(4); opacity: 0; }\n  }\n\n  .node-path {\n    stroke-dasharray: 1000;\n    stroke-dashoffset: 1000;\n  }\n</style>\n\n<div class=\"relative min-h-screen selection:bg-[#d9f99d]/30 selection:text-white\" data-kid=\"1\">\n  \n  <div class=\"fixed inset-0 pointer-events-none\" data-kid=\"2\">\n    <div class=\"mesh-gradient absolute inset-0 opacity-40\" data-kid=\"3\"></div>\n    <div class=\"floating-orb w-[400px] h-[400px] bg-purple-500/10 top-[-10%] right-[10%]\" style=\"animation-delay: -2s\" data-kid=\"4\"></div>\n    <div class=\"floating-orb w-[300px] h-[300px] bg-teal-500/10 bottom-[20%] left-[5%]\" style=\"animation-delay: -5s\" data-kid=\"5\"></div>\n  </div>\n\n  <main class=\"relative z-10 max-w-7xl mx-auto px-6 py-24\" data-kid=\"6\">\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-40 items-end\" data-kid=\"7\">\n      <div class=\"lg:col-span-7\" id=\"hero-content\" data-kid=\"8\">\n        <span class=\"inline-block font-sans text-xs uppercase tracking-[0.3em] text-accent mb-6 opacity-0 translate-y-4 reveal\" data-kid=\"9\">Esteban — About Me</span>\n        <h1 class=\"text-5xl md:text-7xl lg:text-8xl font-semibold leading-[0.9] tracking-tight mb-10\" data-kid=\"10\">\n          <span class=\"font-serif italic text-white block reveal opacity-0 translate-y-8\" style=\"transition-delay: 0.1s\" data-kid=\"11\">Bioengineered</span>\n          <span class=\"font-sans text-[#c8bfff] block reveal opacity-0 translate-y-8\" style=\"transition-delay: 0.2s\" data-kid=\"12\">Architecture.</span>\n        </h1>\n        <p class=\"text-lg md:text-xl text-gray-400 max-w-xl leading-relaxed font-sans reveal opacity-0 translate-y-8\" style=\"transition-delay: 0.3s\" data-kid=\"13\">\n          Synthesizing biological precision with scalable software architecture. From decoding physiological signals to orchestrating high-throughput data pipelines.\n        </p>\n      </div>\n      <div class=\"lg:col-span-5 relative\" data-kid=\"14\">\n        <div class=\"relative group reveal opacity-0 scale-95\" style=\"transition-delay: 0.4s\" data-kid=\"15\">\n          <div class=\"absolute inset-0 bg-vitality/20 blur-3xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-1000\" data-kid=\"16\"></div>\n          <img src=\"https://images.unsplash.com/photo-1513038918579-a6f01e2d3b92?auto=format&w=800&q=80&fit=crop\" alt=\"Bioluminescence abstract\" class=\"w-full aspect-square object-cover rounded-[2rem] grayscale group-hover:grayscale-0 transition-all duration-1000\" decoding=\"async\" loading=\"lazy\" data-kid=\"17\">\n          <div class=\"absolute -bottom-6 -right-6 glass-card p-6 rounded-2xl border-vitality/20 max-w-[240px]\" data-kid=\"18\">\n            <p class=\"text-sm italic font-serif leading-relaxed text-gray-300\" data-kid=\"19\">\n              \"The most complex systems aren't just built; they are evolved.\"\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-56 relative\" data-kid=\"20\">\n      <div class=\"text-center mb-24\" data-kid=\"21\">\n        <h2 class=\"font-sans text-xs uppercase tracking-[0.3em] text-accent mb-4\" data-kid=\"22\">Evolution Path</h2>\n        <h3 class=\"font-serif italic text-4xl text-white\" data-kid=\"23\">The Career Helix</h3>\n      </div>\n      \n      <div class=\"relative max-w-4xl mx-auto h-[800px]\" data-kid=\"24\">\n        \n        <svg class=\"absolute inset-0 w-full h-full pointer-events-none\" viewBox=\"0 0 400 800\" fill=\"none\" data-kid=\"25\">\n          <path id=\"helix-path\" class=\"node-path\" d=\"M200 0 C350 150, 50 250, 200 400 C350 550, 50 650, 200 800\" stroke=\"url(#helix-gradient)\" stroke-width=\"2\" stroke-linecap=\"round\" data-kid=\"26\"></path>\n          <defs data-kid=\"27\">\n            <linearGradient id=\"helix-gradient\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\" data-kid=\"28\">\n              <stop offset=\"0%\" stop-color=\"#c8bfff\" data-kid=\"29\"></stop>\n              <stop offset=\"50%\" stop-color=\"#2dd4bf\" data-kid=\"30\"></stop>\n              <stop offset=\"100%\" stop-color=\"#d9f99d\" data-kid=\"31\"></stop>\n            </linearGradient>\n          </defs>\n        </svg>\n\n        \n        <div class=\"absolute top-[0%] left-1/2 -translate-x-1/2 helix-node group cursor-pointer\" data-delay=\"0\" data-kid=\"32\">\n          <div class=\"w-16 h-16 rounded-full glass-card flex items-center justify-center border-accent/30 group-hover:border-vitality transition-all duration-500\" data-kid=\"33\">\n            <i class=\"ti ti-school text-2xl\" data-kid=\"34\"></i>\n          </div>\n          <div class=\"absolute left-20 top-0 w-48 opacity-0 group-hover:opacity-100 translate-x-4 group-hover:translate-x-0 transition-all duration-500\" data-kid=\"35\">\n            <h4 class=\"font-serif italic text-xl text-white\" data-kid=\"36\">Bioengineering</h4>\n            <p class=\"text-xs text-gray-400 mt-1\" data-kid=\"37\">Foundations in biological systems and physiological measurement.</p>\n          </div>\n        </div>\n\n        <div class=\"absolute top-[25%] left-[75%] -translate-x-1/2 helix-node group cursor-pointer\" data-delay=\"0.5\" data-kid=\"38\">\n          <div class=\"w-16 h-16 rounded-full glass-card flex items-center justify-center border-teal-400/30 group-hover:border-vitality transition-all duration-500\" data-kid=\"39\">\n            <i class=\"ti ti-microscope text-2xl\" data-kid=\"40\"></i>\n          </div>\n          <div class=\"absolute right-20 top-0 w-48 text-right opacity-0 group-hover:opacity-100 -translate-x-4 group-hover:translate-x-0 transition-all duration-500\" data-kid=\"41\">\n            <h4 class=\"font-serif italic text-xl text-white\" data-kid=\"42\">Clinical Research</h4>\n            <p class=\"text-xs text-gray-400 mt-1\" data-kid=\"43\">Processing clinical datasets and medical signal analysis.</p>\n          </div>\n        </div>\n\n        <div class=\"absolute top-[50%] left-1/2 -translate-x-1/2 helix-node group cursor-pointer\" data-delay=\"1\" data-kid=\"44\">\n          <div class=\"w-16 h-16 rounded-full glass-card flex items-center justify-center border-purple-400/30 group-hover:border-vitality transition-all duration-500\" data-kid=\"45\">\n            <i class=\"ti ti-code text-2xl\" data-kid=\"46\"></i>\n          </div>\n          <div class=\"absolute left-20 top-0 w-48 opacity-0 group-hover:opacity-100 translate-x-4 group-hover:translate-x-0 transition-all duration-500\" data-kid=\"47\">\n            <h4 class=\"font-serif italic text-xl text-white\" data-kid=\"48\">Backend Pivot</h4>\n            <p class=\"text-xs text-gray-400 mt-1\" data-kid=\"49\">Transitioning logic from cells to distributed software systems.</p>\n          </div>\n        </div>\n\n        <div class=\"absolute top-[75%] left-[25%] -translate-x-1/2 helix-node group cursor-pointer\" data-delay=\"1.5\" data-kid=\"50\">\n          <div class=\"w-16 h-16 rounded-full glass-card flex items-center justify-center border-accent/30 group-hover:border-vitality transition-all duration-500\" data-kid=\"51\">\n            <i class=\"ti ti-server text-2xl\" data-kid=\"52\"></i>\n          </div>\n          <div class=\"absolute left-20 top-0 w-48 opacity-0 group-hover:opacity-100 translate-x-4 group-hover:translate-x-0 transition-all duration-500\" data-kid=\"53\">\n            <h4 class=\"font-serif italic text-xl text-white\" data-kid=\"54\">Platform Architect</h4>\n            <p class=\"text-xs text-gray-400 mt-1\" data-kid=\"55\">Designing resilient cloud-native infrastructures.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-56 relative\" id=\"bio-bridge\" data-kid=\"56\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\" data-kid=\"57\">\n        <div class=\"reveal opacity-0 -translate-x-8\" data-kid=\"58\">\n          <h2 class=\"font-sans text-xs uppercase tracking-[0.3em] text-accent mb-6\" data-kid=\"59\">Bio Bridge</h2>\n          <h3 class=\"text-4xl font-semibold mb-8\" data-kid=\"60\">Transferring Knowledge Across Domains</h3>\n          <p class=\"text-gray-400 leading-relaxed mb-10 max-w-prose\" data-kid=\"61\">\n            Bioengineering taught me how to handle noise, latency, and failure in complex biological networks. These same principles define my approach to distributed systems.\n          </p>\n          \n          <div class=\"space-y-4\" data-kid=\"62\">\n            <div class=\"p-4 rounded-xl glass-card group cursor-pointer bio-bridge-item hover:bg-white/5 transition-all\" data-target=\"path-1\" data-kid=\"63\">\n              <div class=\"flex items-center gap-4\" data-kid=\"64\">\n                <span class=\"font-serif italic text-white group-hover:text-vitality transition-colors\" data-kid=\"65\">Signal Processing</span>\n                <i class=\"ti ti-arrow-narrow-right text-gray-600\" data-kid=\"66\"></i>\n                <span class=\"font-sans text-gray-400 group-hover:text-white transition-colors\" data-kid=\"67\">Event Streaming</span>\n              </div>\n            </div>\n            <div class=\"p-4 rounded-xl glass-card group cursor-pointer bio-bridge-item hover:bg-white/5 transition-all\" data-target=\"path-2\" data-kid=\"68\">\n              <div class=\"flex items-center gap-4\" data-kid=\"69\">\n                <span class=\"font-serif italic text-white group-hover:text-vitality transition-colors\" data-kid=\"70\">Homeostasis</span>\n                <i class=\"ti ti-arrow-narrow-right text-gray-600\" data-kid=\"71\"></i>\n                <span class=\"font-sans text-gray-400 group-hover:text-white transition-colors\" data-kid=\"72\">Autoscaling Systems</span>\n              </div>\n            </div>\n            <div class=\"p-4 rounded-xl glass-card group cursor-pointer bio-bridge-item hover:bg-white/5 transition-all\" data-target=\"path-3\" data-kid=\"73\">\n              <div class=\"flex items-center gap-4\" data-kid=\"74\">\n                <span class=\"font-serif italic text-white group-hover:text-vitality transition-colors\" data-kid=\"75\">Metabolic Pathways</span>\n                <i class=\"ti ti-arrow-narrow-right text-gray-600\" data-kid=\"76\"></i>\n                <span class=\"font-sans text-gray-400 group-hover:text-white transition-colors\" data-kid=\"77\">Data Pipelines</span>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"relative aspect-square flex items-center justify-center\" data-kid=\"78\">\n          <div class=\"absolute inset-0 bg-accent/5 rounded-full blur-3xl\" data-kid=\"79\"></div>\n          \n          \n          <div class=\"relative z-10 w-24 h-24 rounded-full glass-card flex items-center justify-center border-vitality/40 shadow-[0_0_30px_rgba(217,249,157,0.1)]\" data-kid=\"80\">\n            <i class=\"ti ti-dna text-3xl text-vitality\" data-kid=\"81\"></i>\n          </div>\n\n          \n          <svg class=\"absolute inset-0 w-full h-full\" viewBox=\"0 0 400 400\" data-kid=\"82\">\n            <path id=\"path-1\" d=\"M200 200 Q200 50, 350 50\" stroke=\"white\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" fill=\"none\" opacity=\"0.1\" data-kid=\"83\"></path>\n            <path id=\"path-2\" d=\"M200 200 Q350 200, 350 350\" stroke=\"white\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" fill=\"none\" opacity=\"0.1\" data-kid=\"84\"></path>\n            <path id=\"path-3\" d=\"M200 200 Q50 200, 50 100\" stroke=\"white\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" fill=\"none\" opacity=\"0.1\" data-kid=\"85\"></path>\n          </svg>\n\n          \n          <div class=\"absolute top-[50px] right-[50px] tech-node opacity-60\" data-kid=\"86\">\n            <div class=\"w-10 h-10 rounded-lg glass-card flex items-center justify-center\" data-kid=\"87\">\n              <i class=\"ti ti-wave-square text-lg\" data-kid=\"88\"></i>\n            </div>\n          </div>\n          <div class=\"absolute bottom-[50px] right-[50px] tech-node opacity-60\" data-kid=\"89\">\n            <div class=\"w-10 h-10 rounded-lg glass-card flex items-center justify-center\" data-kid=\"90\">\n              <i class=\"ti ti-arrows-maximize text-lg\" data-kid=\"91\"></i>\n            </div>\n          </div>\n          <div class=\"absolute top-[100px] left-[50px] tech-node opacity-60\" data-kid=\"92\">\n            <div class=\"w-10 h-10 rounded-lg glass-card flex items-center justify-center\" data-kid=\"93\">\n              <i class=\"ti ti-stack-2 text-lg\" data-kid=\"94\"></i>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"grid grid-cols-1 lg:grid-cols-12 gap-16 mb-40\" data-kid=\"95\">\n      <div class=\"lg:col-span-4 space-y-8\" data-kid=\"96\">\n        <div class=\"grid grid-cols-2 gap-4\" data-kid=\"97\">\n          <div class=\"p-8 rounded-[2rem] glass-card text-center hover:border-vitality/30 transition-all duration-500 reveal opacity-0 scale-95\" style=\"transition-delay: 0.1s\" data-kid=\"98\">\n            <div class=\"text-4xl font-sans font-bold text-white mb-2\" data-kid=\"99\">8+</div>\n            <div class=\"text-[10px] uppercase tracking-widest text-accent\" data-kid=\"100\">Years Coding</div>\n          </div>\n          <div class=\"p-8 rounded-[2rem] glass-card text-center hover:border-vitality/30 transition-all duration-500 reveal opacity-0 scale-95\" style=\"transition-delay: 0.2s\" data-kid=\"101\">\n            <div class=\"text-4xl font-sans font-bold text-white mb-2\" data-kid=\"102\">42</div>\n            <div class=\"text-[10px] uppercase tracking-widest text-accent\" data-kid=\"103\">Projects</div>\n          </div>\n          <div class=\"p-8 rounded-[2rem] glass-card text-center hover:border-vitality/30 transition-all duration-500 reveal opacity-0 scale-95\" style=\"transition-delay: 0.3s\" data-kid=\"104\">\n            <div class=\"text-4xl font-sans font-bold text-white mb-2\" data-kid=\"105\">15</div>\n            <div class=\"text-[10px] uppercase tracking-widest text-accent\" data-kid=\"106\">Technologies</div>\n          </div>\n          <div class=\"p-8 rounded-[2rem] glass-card text-center hover:border-vitality/30 transition-all duration-500 reveal opacity-0 scale-95\" style=\"transition-delay: 0.4s\" data-kid=\"107\">\n            <div class=\"text-4xl font-sans font-bold text-white mb-2\" data-kid=\"108\">4</div>\n            <div class=\"text-[10px] uppercase tracking-widest text-accent\" data-kid=\"109\">Specializations</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"lg:col-span-8 flex flex-col justify-center\" data-kid=\"110\">\n        <div class=\"columns-1 md:columns-2 gap-10 text-gray-400 text-lg leading-relaxed font-sans reveal opacity-0 translate-y-8\" style=\"transition-delay: 0.5s\" data-kid=\"111\">\n          <p class=\"mb-6\" data-kid=\"112\">\n            Mi viaje comenzó en los laboratorios de bioingeniería, donde aprendí a observar patrones en señales fisiológicas ruidosas y a modelar sistemas homeostáticos complejos. Esta formación científica me dio una perspectiva única sobre la <span class=\"text-white italic font-serif\" data-kid=\"113\">resiliencia</span> y la <span class=\"text-white italic font-serif\" data-kid=\"114\">adaptabilidad</span>.\n          </p>\n          <p class=\"mb-6\" data-kid=\"115\">\n            Hoy, aplico esos mismos principios al diseño de arquitecturas de software distribuidas. Entiendo que un sistema, ya sea biológico o digital, debe ser capaz de autorregularse y recuperarse ante fallos inesperados.\n          </p>\n          <p data-kid=\"116\">\n            Me especializo en construir infraestructura robusta, optimizar pipelines de datos masivos y liderar equipos técnicos hacia soluciones que no solo funcionen hoy, sino que puedan evolucionar mañana.\n          </p>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-40\" data-kid=\"117\">\n      <div class=\"text-center mb-16\" data-kid=\"118\">\n        <h2 class=\"font-sans text-xs uppercase tracking-[0.3em] text-accent mb-4\" data-kid=\"119\">Interests</h2>\n        <h3 class=\"font-serif italic text-4xl text-white\" data-kid=\"120\">Curiosities & Explorations</h3>\n      </div>\n      \n      <div class=\"flex flex-wrap justify-center gap-6 max-w-4xl mx-auto\" id=\"interests-container\" data-kid=\"121\">\n        \n        <div class=\"px-8 py-4 rounded-full glass-card border-white/10 hover:border-vitality/50 hover:text-vitality transition-all duration-500 cursor-default reveal opacity-0 scale-50\" style=\"transition-delay: 0.1s\" data-kid=\"122\">\n          <span class=\"text-sm tracking-wide\" data-kid=\"123\">Machine Learning</span>\n        </div>\n        <div class=\"px-8 py-4 rounded-full glass-card border-white/10 hover:border-vitality/50 hover:text-vitality transition-all duration-500 cursor-default reveal opacity-0 scale-50\" style=\"transition-delay: 0.2s\" data-kid=\"124\">\n          <span class=\"text-sm tracking-wide\" data-kid=\"125\">Genomics</span>\n        </div>\n        <div class=\"px-8 py-4 rounded-full glass-card border-white/10 hover:border-vitality/50 hover:text-vitality transition-all duration-500 cursor-default reveal opacity-0 scale-50\" style=\"transition-delay: 0.3s\" data-kid=\"126\">\n          <span class=\"text-sm tracking-wide\" data-kid=\"127\">Distributed Systems</span>\n        </div>\n        <div class=\"px-8 py-4 rounded-full glass-card border-white/10 hover:border-vitality/50 hover:text-vitality transition-all duration-500 cursor-default reveal opacity-0 scale-50\" style=\"transition-delay: 0.4s\" data-kid=\"128\">\n          <span class=\"text-sm tracking-wide\" data-kid=\"129\">Analog Synthesis</span>\n        </div>\n        <div class=\"px-8 py-4 rounded-full glass-card border-white/10 hover:border-vitality/50 hover:text-vitality transition-all duration-500 cursor-default reveal opacity-0 scale-50\" style=\"transition-delay: 0.5s\" data-kid=\"130\">\n          <span class=\"text-sm tracking-wide\" data-kid=\"131\">Computational Biology</span>\n        </div>\n        <div class=\"px-8 py-4 rounded-full glass-card border-white/10 hover:border-vitality/50 hover:text-vitality transition-all duration-500 cursor-default reveal opacity-0 scale-50\" style=\"transition-delay: 0.6s\" data-kid=\"132\">\n          <span class=\"text-sm tracking-wide\" data-kid=\"133\">Platform Engineering</span>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"mb-32\" data-kid=\"134\">\n      <div class=\"flex items-center justify-between mb-16\" data-kid=\"135\">\n        <div data-kid=\"136\">\n          <h2 class=\"font-sans text-xs uppercase tracking-[0.3em] text-accent mb-4\" data-kid=\"137\">Mindset</h2>\n          <h3 class=\"text-4xl font-semibold\" data-kid=\"138\">Core Principles</h3>\n        </div>\n        <div class=\"hidden md:flex gap-4\" data-kid=\"139\">\n          <button class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors\" data-kid=\"140\"><i class=\"ti ti-chevron-left\" data-kid=\"141\"></i></button>\n          <button class=\"w-12 h-12 rounded-full border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors\" data-kid=\"142\"><i class=\"ti ti-chevron-right\" data-kid=\"143\"></i></button>\n        </div>\n      </div>\n      \n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\" data-kid=\"144\">\n        <div class=\"p-10 rounded-[2.5rem] glass-card group hover:bg-white/[0.04] transition-all duration-500 reveal opacity-0 translate-y-12\" style=\"transition-delay: 0.1s\" data-kid=\"145\">\n          <div class=\"w-14 h-14 rounded-2xl bg-accent/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500\" data-kid=\"146\">\n            <i class=\"ti ti-microscope text-2xl text-accent\" data-kid=\"147\"></i>\n          </div>\n          <h4 class=\"text-2xl font-serif italic mb-4 text-white\" data-kid=\"148\">Precision-First</h4>\n          <p class=\"text-gray-400 leading-relaxed\" data-kid=\"149\">Applying clinical-grade attention to detail in every line of code and infrastructure configuration.</p>\n        </div>\n        <div class=\"p-10 rounded-[2.5rem] glass-card group hover:bg-white/[0.04] transition-all duration-500 reveal opacity-0 translate-y-12\" style=\"transition-delay: 0.2s\" data-kid=\"150\">\n          <div class=\"w-14 h-14 rounded-2xl bg-vitality/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500\" data-kid=\"151\">\n            <i class=\"ti ti-refresh text-2xl text-vitality\" data-kid=\"152\"></i>\n          </div>\n          <h4 class=\"text-2xl font-serif italic mb-4 text-white\" data-kid=\"153\">Adaptive Design</h4>\n          <h4 class=\"text-2xl font-serif italic mb-4 text-white\" data-kid=\"154\">Adaptive Design</h4>\n          <p class=\"text-gray-400 leading-relaxed\" data-kid=\"155\">Building systems that embrace failure as a signal for self-correction, much like biological organisms.</p>\n        </div>\n        <div class=\"p-10 rounded-[2.5rem] glass-card group hover:bg-white/[0.04] transition-all duration-500 reveal opacity-0 translate-y-12\" style=\"transition-delay: 0.3s\" data-kid=\"156\">\n          <div class=\"w-14 h-14 rounded-2xl bg-teal-400/10 flex items-center justify-center mb-8 group-hover:scale-110 transition-transform duration-500\" data-kid=\"157\">\n            <i class=\"ti ti-server text-2xl text-teal-400\" data-kid=\"158\"></i>\n          </div>\n          <h4 class=\"text-2xl font-serif italic mb-4 text-white\" data-kid=\"159\">Systemic Scalability</h4>\n          <p class=\"text-gray-400 leading-relaxed\" data-kid=\"160\">Understanding the interconnected nature of services to ensure growth doesn't compromise stability.</p>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <footer class=\"max-w-7xl mx-auto px-6 py-12 border-t border-white/5 flex justify-between items-center text-xs tracking-widest text-gray-500 uppercase font-sans\" data-kid=\"161\">\n    <div data-kid=\"162\">&copy; 2026 Esteban</div>\n    <div class=\"flex gap-8\" data-kid=\"163\">\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"164\">GitHub</a>\n      <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"165\">LinkedIn</a>\n    </div>\n  </footer>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"166\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"167\"></script>\n<script data-kid=\"168\">\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initial Entrance Animations\n  gsap.utils.toArray('.reveal').forEach(el => {\n    gsap.to(el, {\n      opacity: 1,\n      y: 0,\n      scale: 1,\n      duration: 1.2,\n      ease: \"power4.out\",\n      scrollTrigger: {\n        trigger: el,\n        start: \"top 90%\",\n      }\n    });\n  });\n\n  // Helix Path Animation\n  gsap.to('#helix-path', {\n    strokeDashoffset: 0,\n    duration: 3,\n    ease: \"none\",\n    scrollTrigger: {\n      trigger: '#helix-path',\n      start: \"top 60%\",\n      end: \"bottom 40%\",\n      scrub: 1\n    }\n  });\n\n  // Helix Nodes Ripple & Glow\n  document.querySelectorAll('.helix-node').forEach(node => {\n    node.addEventListener('mouseenter', (e) => {\n      const ripple = document.createElement('div');\n      ripple.className = 'ripple';\n      ripple.style.left = '50%';\n      ripple.style.top = '50%';\n      ripple.style.width = '100px';\n      ripple.style.height = '100px';\n      ripple.style.marginLeft = '-50px';\n      ripple.style.marginTop = '-50px';\n      ripple.style.animation = 'ripple-effect 1s ease-out';\n      node.appendChild(ripple);\n      setTimeout(() => ripple.remove(), 1000);\n    });\n  });\n\n  // Bio Bridge Interaction\n  document.querySelectorAll('.bio-bridge-item').forEach(item => {\n    item.addEventListener('mouseenter', () => {\n      const targetId = item.dataset.target;\n      const path = document.getElementById(targetId);\n      gsap.to(path, {\n        opacity: 1,\n        strokeDasharray: \"0 0\",\n        stroke: \"#d9f99d\",\n        duration: 0.5\n      });\n      gsap.to('.tech-node', { opacity: 0.2, duration: 0.3 });\n      // Find the specific tech node or just highlight all\n    });\n    \n    item.addEventListener('mouseleave', () => {\n      const targetId = item.dataset.target;\n      const path = document.getElementById(targetId);\n      gsap.to(path, {\n        opacity: 0.1,\n        strokeDasharray: \"4 4\",\n        stroke: \"white\",\n        duration: 0.5\n      });\n      gsap.to('.tech-node', { opacity: 0.6, duration: 0.3 });\n    });\n  });\n\n  // Ambient Orbs Subtle Movement\n  gsap.to('.floating-orb', {\n    x: \"random(-100, 100)\",\n    y: \"random(-100, 100)\",\n    duration: 15,\n    repeat: -1,\n    yoyo: true,\n    ease: \"sine.inOut\"\n  });\n</script>",

    "var_9b445508d22d": {
      "type": "variant",
      "label": "Variant 3: Stripe - Harmonized Helix",
      "parentId": "var_dd2833ddfd60",
      "themeId": null,
      "rect": {
        "x": 2760,
        "y": 0,
        "w": 1440,

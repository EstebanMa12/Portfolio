    "var_375513c4501c": {
      "type": "variant",
      "label": "Variant 1: Polychromatic Pulse",
      "parentId": "var_9b445508d22d",
      "themeId": null,
      "rect": {
        "x": 6900,
        "y": 0,
        "w": 1280,
